---
// Chapter 03 — Features. Five blocks alternating left/right (.reverse):
//   1. Itemized quotes (real today)
//   2. Photo documentation (real today)
//   3. AI photo inventory (Coming Q3 2026, video asset)
//   4. Live crew tracking (Coming Q3 2026, SVG illustration)
//   5. Bodycam operations (Pilot Q4 2026, SVG illustration)
//
// Honesty contract: AI inventory, live tracking, and bodycam tag forms are
// "soon" / "pilot" — never "real today". Don't relabel. The "target
// overage under N%" phrase derives from PRICING.claims.overagePercent
// (Math.ceil for a clean threshold copy).

import { Image, getImage } from 'astro:assets';
import { PRICING } from '../../lib/pricing';
import clipboard from '../../assets/clipboard.png';
import loadingBoxes from '../../assets/loading-boxes.png';
import phoneScanning from '../../assets/phone-scanning.png';

// AI inventory video poster needs a stable URL string for the <video poster>
// attribute. getImage() resolves a single optimized webp variant we can pass.
const phoneScanningPoster = await getImage({
  src: phoneScanning,
  format: 'webp',
  quality: 82,
  width: 1280,
});

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
---

<section class="chapter" id="features">
  <div class="chapter-header reveal">
    <div class="ch-num">[ 03 ]</div>
    <div class="ch-label">What you actually get</div>
  </div>

  <h2 class="huge reveal">The whole move,<br />on <em>one page</em>.</h2>

  <div class="features">
    <div class="feature-block reveal">
      <div class="feature-tag real">Real today</div>
      <div class="feature-content">
        <h3>Itemized quotes.<br /><em>No hidden fees</em>.</h3>
        <p>
          Hourly billing, line-by-line. Stairs included. No fuel surcharge,
          no weekend upcharge. The quote you get is the bill you pay — target
          overage under {overageThreshold}%.
        </p>
      </div>
      <div class="feature-asset">
        <Image
          src={clipboard}
          alt="Itemized inlet move invoice on a clipboard"
          widths={[480, 768, 1280]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          format="webp"
          quality={82}
          loading="lazy"
        />
      </div>
    </div>

    <div class="feature-block reverse reveal">
      <div class="feature-tag real">Real today</div>
      <div class="feature-content">
        <h3>Photo<br /><em>documentation</em>.</h3>
        <p>
          Every job. Fragile items, before-and-after, load-out. If anything is
          questioned, there is proof. Photos archived for the duration of any
          insurance claim window.
        </p>
      </div>
      <div class="feature-asset">
        <Image
          src={loadingBoxes}
          alt="Inlet Move crew loading boxes into the cargo van"
          widths={[480, 768, 1280]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          format="webp"
          quality={82}
          loading="lazy"
        />
      </div>
    </div>

    <div class="feature-block reveal">
      <div class="feature-tag soon">Coming Q3 2026</div>
      <div class="feature-content">
        <h3>AI photo<br /><em>inventory</em>.</h3>
        <p>
          Walk your home with the camera. We identify items, estimate volume,
          and price the move — without a site visit. A real human reviews
          every output before it becomes a quote.
        </p>
      </div>
      <div class="feature-asset">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          poster={phoneScanningPoster.src}
          aria-label="Phone camera scanning a room to inventory furniture"
          webkit-playsinline
        >
          <source src="/assets/video-03.webm" type="video/webm" />
          <source src="/assets/video-03-720.mp4" type="video/mp4" />
        </video>
      </div>
    </div>

    <div class="feature-block reverse reveal">
      <div class="feature-tag soon">Coming Q3 2026</div>
      <div class="feature-content">
        <h3>Live crew<br /><em>tracking</em>.</h3>
        <p>
          Watch the truck en route. SMS updates today, live map by Q3 2026.
          No more "they said 9, it's 11, where are they."
        </p>
      </div>
      <div class="feature-asset svg-illust" aria-label="Decorative map illustration showing pickup, en-route van, and drop-off">
        <svg viewBox="0 0 400 220" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;">
          <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(244,241,234,0.06)" stroke-width="0.5" />
            </pattern>
          </defs>
          <rect width="400" height="220" fill="url(#grid)" />
          <path d="M 0 110 Q 80 90, 160 120 T 320 100 L 400 130" fill="none" stroke="rgba(244,241,234,0.12)" stroke-width="14" stroke-linecap="round" />
          <path d="M 50 105 Q 100 95, 160 118" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-dasharray="4 3" />
          <circle cx="50" cy="105" r="7" fill="var(--bg)" stroke="var(--accent)" stroke-width="2" />
          <circle cx="50" cy="105" r="3" fill="var(--accent)" />
          <text x="50" y="85" text-anchor="middle" font-size="9" fill="rgba(244,241,234,0.55)" font-family="JetBrains Mono, monospace" letter-spacing="1.5">PICKUP</text>
          <g transform="translate(160, 118)">
            <rect x="-12" y="-8" width="24" height="14" rx="2" fill="var(--accent)" />
            <rect x="-7" y="-6" width="9" height="6" fill="rgba(244,241,234,0.4)" />
            <circle cx="-7" cy="8" r="3" fill="rgba(0,0,0,0.7)" />
            <circle cx="6" cy="8" r="3" fill="rgba(0,0,0,0.7)" />
            <circle r="22" fill="none" stroke="var(--accent)" stroke-width="1.5" opacity="0.4" />
          </g>
          <text x="160" y="160" text-anchor="middle" font-size="10" fill="var(--accent)" font-family="JetBrains Mono, monospace" font-weight="500" letter-spacing="1">EN ROUTE · 12 MIN</text>
          <circle cx="340" cy="100" r="7" fill="var(--bg)" stroke="rgba(244,241,234,0.45)" stroke-width="2" />
          <text x="340" y="80" text-anchor="middle" font-size="9" fill="rgba(244,241,234,0.55)" font-family="JetBrains Mono, monospace" letter-spacing="1.5">DROP-OFF</text>
          <path d="M 175 118 Q 250 105, 335 100" fill="none" stroke="rgba(244,241,234,0.25)" stroke-width="2" stroke-dasharray="3 4" />
        </svg>
      </div>
    </div>

    <div class="feature-block reveal">
      <div class="feature-tag pilot">Pilot Q4 2026</div>
      <div class="feature-content">
        <h3>Bodycam<br /><em>operations</em>.</h3>
        <p>
          For senior and multigenerational moves. You see what we see. Footage
          archived 90 days. Designed for moves where extra accountability
          matters most.
        </p>
      </div>
      <div class="feature-asset svg-illust" aria-label="Decorative illustration of a body-camera viewfinder labeled REC">
        <svg viewBox="0 0 280 180" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;">
          <rect x="20" y="20" width="240" height="140" rx="10" fill="rgba(5,5,5,0.92)" stroke="rgba(231,111,81,0.4)" stroke-width="1.5" />
          <circle cx="38" cy="34" r="4" fill="var(--accent)" />
          <text x="48" y="38" font-size="9" fill="var(--fg)" letter-spacing="1.5" font-weight="500" font-family="JetBrains Mono, monospace">REC · 14:32</text>
          <line x1="140" y1="75" x2="140" y2="105" stroke="rgba(244,241,234,0.4)" stroke-width="1" />
          <line x1="125" y1="90" x2="155" y2="90" stroke="rgba(244,241,234,0.4)" stroke-width="1" />
          <rect x="100" y="88" width="80" height="42" rx="2" fill="rgba(244,241,234,0.15)" stroke="rgba(244,241,234,0.35)" />
          <text x="140" y="113" text-anchor="middle" font-size="8" fill="rgba(244,241,234,0.6)" font-family="JetBrains Mono, monospace">FRAGILE</text>
          <text x="38" y="148" font-size="7" fill="rgba(244,241,234,0.5)" letter-spacing="0.5" font-family="JetBrains Mono, monospace">VAN-01 · 49.2827°N 123.1207°W</text>
          <rect x="200" y="142" width="50" height="14" rx="7" fill="rgba(231,111,81,0.2)" />
          <text x="225" y="152" text-anchor="middle" font-size="7" fill="var(--accent-soft)" letter-spacing="1" font-weight="500" font-family="JetBrains Mono, monospace">PILOT</text>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .chapter {
    min-height: 100vh;
    padding: 12rem 5vw;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 768px) {
    .chapter { padding: 7rem 1.5rem; }
  }

  .chapter-header {
    display: grid;
    grid-template-columns: 1fr 4fr;
    gap: 3rem;
    align-items: baseline;
    margin-bottom: 5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .chapter-header {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-bottom: 3rem;
    }
  }

  .ch-num {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--fg-3);
  }
  .ch-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-2);
  }

  h2.huge {
    font-family: var(--serif);
    font-size: clamp(2.75rem, 9vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-weight: 300;
    max-width: 14ch;
  }
  h2.huge em {
    font-style: italic;
    color: var(--accent);
  }
  @media (max-width: 768px) {
    h2.huge { font-size: clamp(2.5rem, 11vw, 4rem); }
  }

  .features { margin-top: 4rem; }

  .feature-block {
    padding: 6rem 0;
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: auto 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }
  .feature-block:last-child { border-bottom: 0; }
  .feature-block.reverse { grid-template-columns: 1.2fr 1fr auto; }
  .feature-block.reverse .feature-tag {
    grid-column: 3;
    grid-row: 1;
    padding-top: 0;
  }
  .feature-block.reverse .feature-content {
    grid-column: 2;
    grid-row: 1;
  }
  .feature-block.reverse .feature-asset {
    grid-column: 1;
    grid-row: 1;
  }
  @media (max-width: 1024px) {
    .feature-block,
    .feature-block.reverse {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 4rem 0;
    }
    .feature-block.reverse .feature-tag,
    .feature-block.reverse .feature-content,
    .feature-block.reverse .feature-asset {
      grid-column: 1;
      grid-row: auto;
    }
  }

  .feature-tag {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    padding-top: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    align-self: start;
  }
  .feature-tag::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .feature-tag.real { color: rgba(168, 200, 130, 0.85); }
  .feature-tag.real::before { background: rgba(168, 200, 130, 0.85); }
  .feature-tag.soon { color: var(--accent-soft); }
  .feature-tag.soon::before { background: var(--accent-soft); }
  .feature-tag.pilot { color: var(--accent-soft); }
  .feature-tag.pilot::before { background: var(--accent-soft); }

  .feature-content h3 {
    font-family: var(--serif);
    font-size: clamp(2.25rem, 4.8vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
    font-weight: 300;
    margin-bottom: 1.5rem;
    max-width: 14ch;
  }
  .feature-content h3 em {
    font-style: italic;
    color: var(--accent);
  }
  .feature-content p {
    color: var(--fg-2);
    font-size: 1.05rem;
    max-width: 50ch;
    line-height: 1.55;
  }
  @media (max-width: 768px) {
    .feature-content h3 { font-size: clamp(2rem, 8vw, 3.5rem); }
  }

  .feature-asset {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 4 / 3;
    box-shadow: 0 30px 60px -25px rgba(0, 0, 0, 0.5);
    background: rgba(244, 241, 234, 0.04);
  }
  .feature-asset img,
  .feature-asset video {
    width: 100%;
    height: 110%;
    object-fit: cover;
    display: block;
    will-change: transform;
    filter: saturate(0.94) contrast(1.04);
  }
  .feature-asset.svg-illust {
    padding: 1.5rem;
    box-shadow: none;
  }
</style>
