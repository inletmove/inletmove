---
// TierHero — sub-page hero variant for /[tier]-movers pages. Static photo
// background (no scroll-scrubbed video — that's home-only), tier-specific
// H1 with optional <em> emphasis, price-math subtitle derived from the
// tier helper, single magnetic CTA to the quote app.
//
// Reused across all 6 tier pages by passing the relevant tierEstimate()
// result + a photo from the kit.

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { PRICING, type TierEstimate } from '../../lib/pricing';

/**
 * heroQuality override exists for high-entropy photos (sectional + texture
 * density) where q=82 produces files large enough to fail mobile Lighthouse
 * LCP gate. Default q=82 is correct for clean-composition photos like
 * hero-van. Use lower values (60-75) only when the LCP gate forces it.
 *
 * Calibration history: /1-bedroom-movers ran sofa-carry at q=82 → 768w
 * webp = 127 KB → mobile LCP 3.5 s → Performance 89 (below ≥90 gate).
 * See build report "E7-2 LCP regression resolution — Path B execution"
 * for the chosen value and PSNR result.
 */
interface Props {
  tier: TierEstimate;
  photo: ImageMetadata;
  photoAlt: string;
  h1Html: string;
  intro: string;
  heroQuality?: number;
}

const { tier, photo, photoAlt, h1Html, intro, heroQuality = 82 } = Astro.props;
---

<section class="tier-hero">
  <div class="tier-hero-bg">
    <Image
      src={photo}
      alt={photoAlt}
      class="tier-hero-img"
      widths={[480, 768, 1280, 1920]}
      sizes="100vw"
      format="webp"
      quality={heroQuality}
      loading="eager"
      fetchpriority="high"
    />
    <div class="tier-hero-overlay"></div>
  </div>

  <div class="reveal">
    <div class="tier-hero-eyebrow">[ TIER ] &nbsp;{tier.label} moves · Metro Vancouver</div>
  </div>

  <h1 class="tier-hero-title reveal" set:html={h1Html} />

  <div class="tier-hero-meta reveal">
    <p class="tier-hero-sub">
      {intro}<br />
      <strong>{tier.hoursLabel}</strong> typical · <strong>{tier.rangeLabel}</strong> · two movers + cargo van.
    </p>
    <a href={PRICING.links.quote} class="cta-button magnetic">
      Get a quote <span class="arrow">→</span>
    </a>
  </div>
</section>

<style>
  .tier-hero {
    min-height: 75vh;
    position: relative;
    padding: 9rem 5vw 4rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }
  .tier-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .tier-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .tier-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        90deg,
        rgba(10, 10, 10, 0.92) 0%,
        rgba(10, 10, 10, 0.78) 35%,
        rgba(10, 10, 10, 0.4) 65%,
        rgba(10, 10, 10, 0.55) 100%
      ),
      linear-gradient(
        180deg,
        rgba(10, 10, 10, 0.5) 0%,
        rgba(10, 10, 10, 0.15) 30%,
        rgba(10, 10, 10, 0.7) 100%
      );
  }
  .tier-hero > *:not(.tier-hero-bg) { position: relative; z-index: 2; }

  .tier-hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--fg-2);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .tier-hero-eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .tier-hero-title {
    font-family: var(--serif);
    font-size: clamp(2.75rem, 9vw, 8.5rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    font-weight: 300;
    max-width: 16ch;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.5);
  }
  .tier-hero-title :global(em) {
    font-style: italic;
    color: var(--accent);
  }

  .tier-hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 4rem;
    flex-wrap: wrap;
  }
  .tier-hero-sub {
    max-width: 44ch;
    font-size: 1.05rem;
    color: var(--fg);
    line-height: 1.55;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
  }
  .tier-hero-sub strong {
    color: var(--fg);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .tier-hero { padding: 7rem 1.5rem 3rem; }
    .tier-hero-title { font-size: clamp(2.25rem, 11vw, 4rem); }
  }
</style>
