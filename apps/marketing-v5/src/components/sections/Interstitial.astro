---
// Cinematic interstitial — full-bleed parked-van video between Service Area
// and Trust. Below-fold autoplay loop, so it lazy-loads via the shared
// LazyVideo component (preload="none" + IntersectionObserver). Saves
// ~880 KB of bandwidth on slow 4G when the user doesn't scroll past Trust.
// Hero video stays eager (it IS the fold); only this one and any future
// below-fold autoplay loops get the lazy treatment.

import LazyVideo from '../shared/LazyVideo.astro';
---

<section class="interstitial" aria-hidden="true">
  <LazyVideo
    sources={[
      { src: '/assets/video-01.webm', type: 'video/webm' },
      { src: '/assets/video-01-720.mp4', type: 'video/mp4' },
    ]}
    poster="/assets/hero-van-poster.webp"
  />
  <div class="interstitial-caption">
    <div class="left">
      <span>[ —— ]</span>
      <span>An intermission · Vancouver · golden hour</span>
    </div>
    <div class="right">A van, <em>at rest</em>.</div>
  </div>
</section>

<style>
  .interstitial {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background: #000;
  }
  .interstitial :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .interstitial::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.4) 0%,
      transparent 25%,
      transparent 75%,
      rgba(10, 10, 10, 0.6) 100%
    );
    pointer-events: none;
  }
  .interstitial-caption {
    position: absolute;
    bottom: 3rem;
    left: 5vw;
    right: 5vw;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--fg-2);
    text-transform: uppercase;
    z-index: 2;
  }
  .interstitial-caption .left {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .interstitial-caption .right {
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--fg);
    letter-spacing: -0.01em;
    text-transform: none;
  }
  .interstitial-caption .right em { color: var(--accent); }

  @media (max-width: 768px) {
    .interstitial { height: 70vh; }
    .interstitial-caption {
      flex-direction: column;
      gap: 0.75rem;
      bottom: 2rem;
    }
  }
</style>
