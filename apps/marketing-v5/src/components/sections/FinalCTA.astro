---
/**
 * Chapter 06 — Final CTA. Big magnetic button → PRICING.links.quote.
 * "Or call" sub-line shows the phone only when active.
 */

import { PRICING } from '../../lib/pricing';

interface Props {
  // Chapter number for this section. Default '06' matches the home's
  // 6-chapter narrative. Sub-pages override to follow their local
  // chapter count — e.g. tier pages pass num="03". See Trust.astro
  // for the parameterization pattern.
  num?: string;
}

const { num = '06' } = Astro.props;
---

<section class="cta-section" id="cta">
  <div class="chapter-header reveal">
    <div class="ch-num">[ {num} ]</div>
    <div class="ch-label">Get a quote</div>
  </div>

  <h2 class="huge reveal">60 seconds<br />to your <em>quote</em>.</h2>

  <a href={PRICING.links.quote} class="cta-button cta-button--large magnetic reveal">
    Get a quote
    <span class="arrow">→</span>
  </a>

  {PRICING.phone.active && (
    <p class="cta-sub reveal">
      Or call <a href={`tel:${PRICING.phone.tel}`}>{PRICING.phone.vanity}</a> · Same-week local moves
    </p>
  )}

  <span class="outro-mark" aria-hidden="true">Inlet&nbsp;Move.</span>
</section>

<style>
  .cta-section {
    min-height: 100vh;
    padding: 14rem 5vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(231, 111, 81, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .cta-section { padding: 7rem 1.5rem; }
  }

  .chapter-header {
    display: grid;
    grid-template-columns: 1fr 4fr;
    gap: 3rem;
    align-items: baseline;
    margin-bottom: 5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .chapter-header {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-bottom: 3rem;
    }
  }

  .ch-num {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--fg-3);
  }
  .ch-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-2);
  }

  h2.huge {
    font-family: var(--serif);
    font-size: clamp(2.75rem, 9vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-weight: 300;
    max-width: 14ch;
  }
  h2.huge em {
    font-style: italic;
    color: var(--accent);
  }
  @media (max-width: 768px) {
    h2.huge { font-size: clamp(2.5rem, 11vw, 4rem); }
  }

  .cta-button--large {
    margin-top: 4rem;
    align-self: flex-start;
  }

  .cta-sub {
    margin-top: 2rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--fg-3);
    letter-spacing: 0.1em;
  }
  .cta-sub a {
    color: var(--fg);
    text-decoration: none;
  }
  .cta-sub a:hover { color: var(--accent); }

  .outro-mark {
    display: block;
    font-family: var(--serif);
    font-size: clamp(4rem, 18vw, 22rem);
    line-height: 0.85;
    letter-spacing: -0.06em;
    color: var(--fg);
    opacity: 0.05;
    pointer-events: none;
    margin: 6rem -2vw -3rem;
    white-space: nowrap;
    font-style: italic;
  }
  @media (max-width: 768px) {
    .outro-mark { display: none; }
  }
</style>
