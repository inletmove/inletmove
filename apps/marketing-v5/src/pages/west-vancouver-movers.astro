---
// /west-vancouver-movers — final city page in E8. Same shape as
// prior city pages.
//
// Photo: hero-van.png reused.
//
// Logistics fact chosen: option (a) — British Properties driveway
// geometry. Embedded near the top as the operational signature of
// the city. Option (b) — estate-scale move concentration — folded
// in operationally ("the longest carry on a job sometimes outpaces
// the loading itself") rather than as a selling point. Option (c)
// — Hwy 1 / Marine Drive / Lions Gate access — folded into the
// opening geographic frame. Option (d) — Horseshoe Bay BC Ferries
// timing — folded into the Horseshoe Bay neighborhood enumeration.
// Option (e) — privacy/white-glove framing — DELIBERATELY NOT
// included, per Feroz directive: West Van gets the same crew, same
// rate, same care as a studio move in East Van. Operational
// specificity is the value, not service-tier inflation.
//
// Closing line ties the brand discipline explicitly: "Same crew,
// same rate, same care as a move in East Van" — the anti-white-
// glove framing made visible.
//
// Step F redirects flagged for vercel.json (NOT implemented):
//   /lions-bay-movers          → 301 → /west-vancouver-movers
//   /horseshoe-bay-movers      → 301 → /west-vancouver-movers
//   /british-properties-movers → 301 → /west-vancouver-movers
//   /ambleside-movers          → 301 → /west-vancouver-movers
//
// Nearby cities: North Vancouver (adjacent east, same North
// Shore), Vancouver (south across Lions Gate), Burnaby (via Lions
// Gate + Hwy 1). Three picked; Coquitlam is a real stretch from
// West Van and dropped.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/west-vancouver-movers';

const city = {
  name: 'West Vancouver',
  neighborhoods: ['British Properties', 'Ambleside', 'Dundarave', 'Horseshoe Bay'],
};

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
const localDetail =
  `West Vancouver runs along the west portion of the North Shore from the Capilano River to Horseshoe Bay, built on the slopes of Cypress and Hollyburn Mountains, with Highway 1 and Marine Drive as the access spine and the Lions Gate Bridge as the only direct link to Vancouver. The British Properties define the city's operational signature: large-lot estates on the steep hillside above Highway 1, where private driveways grade up to twenty-five percent in places and run several hundred metres from the gate to the front door. Some of those gradients exceed what a loaded cargo van can safely stage on — we park at the gate or the street and carry, the same way we'd handle a downtown high-rise's loading bay (different reasons, same discipline). Four neighborhoods worth naming: British Properties, the estate hillside above, where the longest carry on a job sometimes outpaces the loading itself; Ambleside, the urban heart along Marine Drive with mid-rise condos and a walkable village feel — buildings here have proper loading bays and the freight-elevator coordination is straightforward; Dundarave, just west of Ambleside, smaller-scale buildings and the same village rhythm; and Horseshoe Bay at the western end, the ferry-terminal village nearly forty minutes from downtown Vancouver by car — we plan around BC Ferries traffic when the schedule converges with our load-out window. Same crew, same rate, same care as a move in East Van; the quote we send is the bill you pay; target overage under ${overageThreshold}%.`;

const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tiers = tierSlugs.map((slug) => ({
  estimate: tierEstimate(slug),
  href: `/${slug}-movers`,
}));

const nearbyCities = [
  { name: 'North Vancouver', href: '/north-vancouver-movers' },
  { name: 'Vancouver', href: '/vancouver-movers' },
  { name: 'Burnaby', href: '/burnaby-movers' },
];

const title = 'Movers in West Vancouver — Inlet Move Co.';
const description = `Local moves across West Vancouver — British Properties, Ambleside, Dundarave, Horseshoe Bay. Two movers + cargo van, $${PRICING.rates.hourlyRate}/hr, same-week availability across the North Shore.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Service area', item: `${SITE}/service-area` },
    { '@type': 'ListItem', position: 3, name: city.name, item: `${SITE}${PATH}` },
  ],
};

const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  '@id': `${SITE}${PATH}#business`,
  name: `Inlet Move Co. — ${city.name}`,
  url: `${SITE}${PATH}`,
  parentOrganization: { '@id': `${SITE}/#organization` },
  description: `Local moving company serving ${city.name}, BC. Two movers + cargo van, hourly billing from $${PRICING.rates.hourlyRate}/hr, same-week local moves. Same crew, same rate, same care across the North Shore — British Properties driveway geometry included.`,
  areaServed: { '@type': 'City', name: `${city.name}, BC, Canada` },
  knowsLanguage: ['en'],
  ...(PRICING.phone.active ? { telephone: PRICING.phone.tel } : {}),
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: PRICING.links.quote,
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
      ],
    },
    result: { '@type': 'Reservation', name: 'Moving quote request' },
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, cityBusinessSchema]}
>
  <CityHero
    city={city.name}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a West Vancouver hillside street, golden-hour afternoon"
    neighborhoods={city.neighborhoods.join(' · ')}
    h1Html={`Movers in <em>${city.name}</em>.`}
    intro={`Same-week local moves across ${city.name}.`}
  />

  <Chapter
    num="01"
    label="Local detail"
    titleHtml={`${city.name}, in <em>particular</em>.`}
    id="local-detail"
  >
    <p class="local-detail reveal">{localDetail}</p>
  </Chapter>

  <Chapter
    num="02"
    label="Service tiers"
    titleHtml="Pick your <em>tier</em>."
    id="tiers"
  >
    <ul class="tier-grid reveal-stagger">
      {tiers.map((t) => (
        <li>
          <a class="tier-link" href={t.href}>
            <span class="tier-link-name">{t.estimate.label}</span>
            <span class="tier-link-meta">{t.estimate.hoursLabel} · {t.estimate.rangeLabel}</span>
            <span class="tier-link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="03"
    label="Nearby"
    titleHtml="Across the <em>region</em>."
    id="nearby"
  >
    <ul class="nearby-grid reveal-stagger">
      {nearbyCities.map((c) => (
        <li>
          <a class="nearby-link" href={c.href}>
            <em>{c.name}</em>
            <span class="nearby-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Chapter>

  <Trust num="04" />
  <FinalCTA num="05" />
</Base>

<style>
  .local-detail {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }

  .tier-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
  .tier-grid li:nth-last-child(-n+2) .tier-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .tier-grid li:not(:last-child) .tier-link { border-bottom: none; }
    .tier-grid li:last-child .tier-link { border-bottom: 1px solid var(--line); }
  }

  .tier-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .tier-link:hover { padding-left: 1rem; }

  .tier-link-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .tier-link-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-2);
    letter-spacing: 0.06em;
  }
  .tier-link-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .tier-link:hover .tier-link-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .nearby-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .nearby-grid { grid-template-columns: 1fr; }
  }
  .nearby-grid li:nth-last-child(-n+2) .nearby-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .nearby-grid li:not(:last-child) .nearby-link { border-bottom: none; }
    .nearby-grid li:last-child .nearby-link { border-bottom: 1px solid var(--line); }
  }

  .nearby-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .nearby-link em {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-style: italic;
    letter-spacing: -0.02em;
    transition: color 400ms var(--ease);
  }
  .nearby-link:hover { padding-left: 1rem; }
  .nearby-link:hover em { color: var(--accent); }
  .nearby-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .nearby-link:hover .nearby-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }
</style>
