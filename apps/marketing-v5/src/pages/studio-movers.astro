---
// /studio-movers — service-tier page (1 of 5 remaining tier pages in E7).
// Same TierHero + Chapter + Trust + FinalCTA scaffold as /2-bedroom-movers.
// Variations: studio-specific TierHero intro (downtown high-rise + walk-up
// realities, not generic "small apartment" boilerplate), include-grid
// items 3 and 4 retuned for studio operational reality (lobby meet-and-
// greet, freight-elevator booking).
//
// Photo: hero-van.png — clean brand image, doesn't presuppose a specific
// move type. /2-bedroom-movers uses loading-boxes; using a different
// photo here keeps the tier rotation visually distinct.

import Base from '../layouts/Base.astro';
import TierHero from '../components/sections/TierHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, quoteUrlAbsolute } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const tier = tierEstimate('studio');
const SITE = 'https://inletmove.ca';
const PATH = '/studio-movers';

const title = `Studio movers in Metro Vancouver — Inlet Move`;
const description =
  `Two movers + cargo van. ${tier.label} moves typically take ${tier.hoursLow}–${tier.hoursHigh} hours, ${tier.rangeLabel} total. Same-week local moves across Metro Vancouver.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE}/services` },
    { '@type': 'ListItem', position: 3, name: 'Studio movers', item: `${SITE}${PATH}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE}${PATH}#service`,
  name: 'Studio apartment move',
  serviceType: 'Local moving service',
  category: 'Residential moving',
  description:
    `${tier.label} apartment moves with a two-mover crew + cargo van. ${tier.hoursLabel} typical, ${tier.rangeLabel} total. Hourly billing, photo-documented, no fuel or stair surcharges. Common Metro Vancouver scenario: downtown high-rise with booked freight elevator.`,
  provider: { '@id': `${SITE}/#business` },
  areaServed: { '@type': 'AdministrativeArea', name: 'Metro Vancouver, BC, Canada' },
  url: `${SITE}${PATH}`,
  offers: {
    '@type': 'Offer',
    name: 'Studio apartment move',
    priceCurrency: PRICING.currency,
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: tier.priceLow,
      maxPrice: tier.priceHigh,
      priceCurrency: PRICING.currency,
      unitText: 'per move',
    },
    availability: 'https://schema.org/InStock',
    url: quoteUrlAbsolute(),
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, serviceSchema]}
>
  <TierHero
    tier={tier}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a Vancouver downtown street, a typical studio-move pickup"
    h1Html="Studio apartment <em>movers</em>."
    intro="One-room loads — the lightest move on the menu. Usually a downtown high-rise with booked freight elevators, sometimes a West End walk-up where the only complication is which way the bedframe turns coming down the stairs."
  />

  <Chapter
    num="01"
    label="What's included"
    titleHtml={`${tier.hoursLabel}.<br /><em>${tier.rangeLabel}</em> total.`}
    id="includes"
  >
    <div class="includes-grid reveal-stagger">
      <div class="include-item">
        <div class="label">Hourly rate</div>
        <div class="value">from ${PRICING.rates.hourlyRate}<em>/hr</em></div>
        <div class="footnote">Two movers + cargo van. ${PRICING.rates.minimumCharge} minimum ({PRICING.rates.minimumHours} hours). Rate depends on vehicle and type of move.</div>
      </div>
      <div class="include-item">
        <div class="label">Quote = bill</div>
        <div class="value">No <em>surprises</em></div>
        <div class="footnote">Target overage under {Math.ceil(PRICING.claims.overagePercent)}%. No fuel, stair, or weekend fees.</div>
      </div>
      <div class="include-item">
        <div class="label">Photo documentation</div>
        <div class="value"><em>Same</em> archive</div>
        <div class="footnote">Every fragile item, before-and-after rooms, the lobby load-out. Studio loads are smaller; the documentation isn't.</div>
      </div>
      <div class="include-item">
        <div class="label">Building coordination</div>
        <div class="value">Lobby <em>meet</em></div>
        <div class="footnote">We file the freight-elevator booking with your building manager — typically twenty-four hours' notice. Crew briefed on parking, stairs, and stair geometry before arrival.</div>
      </div>
    </div>
    <Terms variant="block" />
  </Chapter>

  <Trust num="02" />
  <FinalCTA num="03" />
</Base>

<style>
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-top: 4rem;
  }
  @media (max-width: 768px) {
    .includes-grid { grid-template-columns: 1fr; }
  }

  .include-item {
    border-top: 1px solid var(--line);
    padding: 1.75rem 2rem 1.75rem 0;
  }
  .include-item .label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .include-item .value {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .include-item .value em {
    font-style: italic;
    color: var(--accent);
  }
  .include-item .footnote {
    font-size: 0.85rem;
    color: var(--fg-2);
    margin-top: 0.5rem;
    max-width: 38ch;
  }
</style>
