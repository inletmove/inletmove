---
// /richmond-movers — second city page in E8. Same shape as
// /vancouver-movers and /burnaby-movers. Richmond-specific
// 200-word local-detail prose. Find-replace test: the prose
// should not survive Richmond → Vancouver or Richmond → Burnaby.
//
// Photo: hero-van.png reused from prior city pages.
//
// Logistics fact chosen: option (b) — Richmond's flat delta
// geography means stairs and basements are rarely the issue,
// inverting the operational picture from Vancouver/Burnaby. This
// is the most architecturally distinct of the four options Feroz
// offered. Embedded as the SECOND sentence of the prose, before
// the neighborhood enumeration, so it frames the rest of the
// reading.
//
// Nearby cities: Feroz directive named Vancouver/Delta/New
// Westminster. Delta is NOT in Inlet's 8-city service area
// (service-area.astro + Footer cities don't include it). Using
// Vancouver + New Westminster + Burnaby + Surrey (four actually-
// served cities, geographically nearest to Richmond by bridge or
// proximity). Surfaced in build report.
//
// Terms mounted at end of Chapter 02 — matches /burnaby-movers
// and the retroactively-corrected /vancouver-movers.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/richmond-movers';

const city = {
  name: 'Richmond',
  neighborhoods: ['Steveston', 'City Centre', 'Brighouse', 'Thompson', 'Sea Island'],
};

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
const localDetail =
  `Richmond is built on the Fraser delta — flat as a parking lot, with a water table that sits close to the surface and a long history of agricultural-reserve land limiting what can go where. Many houses don't have basements, or have shallow ones, which inverts the operational picture from Vancouver and Burnaby: stairs are rare on the inside of a Richmond move, basements are rare to clear, and most loads come out at ground level into the cargo van. Four neighborhoods worth naming: Steveston, the heritage fishing-village pocket on the south side, where the older single-family streets are narrow and some character-area bylaws apply on the front-facade — we file paperwork ahead when a destination touches one of those; City Centre around Brighouse and the malls (Richmond Centre, Lansdowne), where tower density rivals Metrotown but freight-elevator and loading-bay schedules often track the surrounding retail and restaurant patterns rather than a strict morning rhythm — we book whatever window the building offers; Thompson and Terra Nova, newer single-family stock with larger lots and longer driveways; Sea Island near YVR, where rental cycles run on airline-employment rotations rather than calendar months. Most Richmond moves run three to six hours — the rate is the same as anywhere else in Metro Vancouver; the quote we send is the bill you pay; target overage under ${overageThreshold}%.`;

const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tiers = tierSlugs.map((slug) => ({
  estimate: tierEstimate(slug),
  href: `/${slug}-movers`,
}));

// Nearby cities: Vancouver (north, across Oak/Knight/Arthur Laing
// bridges), New Westminster (east, across the Fraser via Queensborough),
// Burnaby (north-east via Knight Street into Burnaby), Surrey (south-
// east via Alex Fraser). Delta is geographically Richmond's southern
// neighbor but is NOT in Inlet's service area — flagged in build report.
const nearbyCities = [
  { name: 'Vancouver', href: '/vancouver-movers' },
  { name: 'New Westminster', href: '/new-westminster-movers' },
  { name: 'Burnaby', href: '/burnaby-movers' },
  { name: 'Surrey', href: '/surrey-movers' },
];

const title = 'Movers in Richmond — Inlet Move Co.';
const description = `Local moves across Richmond — Steveston, City Centre, Brighouse, Thompson, Sea Island. Two movers + cargo van, $${PRICING.rates.hourlyRate}/hr, same-week availability across the city.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Service area', item: `${SITE}/service-area` },
    { '@type': 'ListItem', position: 3, name: city.name, item: `${SITE}${PATH}` },
  ],
};

const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  '@id': `${SITE}${PATH}#business`,
  name: `Inlet Move Co. — ${city.name}`,
  url: `${SITE}${PATH}`,
  parentOrganization: { '@id': `${SITE}/#organization` },
  description: `Local moving company serving ${city.name}, BC. Two movers + cargo van, hourly billing from $${PRICING.rates.hourlyRate}/hr, same-week local moves.`,
  areaServed: { '@type': 'City', name: `${city.name}, BC, Canada` },
  knowsLanguage: ['en'],
  ...(PRICING.phone.active ? { telephone: PRICING.phone.tel } : {}),
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: PRICING.links.quote,
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
      ],
    },
    result: { '@type': 'Reservation', name: 'Moving quote request' },
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, cityBusinessSchema]}
>
  <CityHero
    city={city.name}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a Richmond residential street, golden-hour afternoon"
    neighborhoods={city.neighborhoods.join(' · ')}
    h1Html={`Movers in <em>${city.name}</em>.`}
    intro={`Same-week local moves across ${city.name}.`}
  />

  <Chapter
    num="01"
    label="Local detail"
    titleHtml={`${city.name}, in <em>particular</em>.`}
    id="local-detail"
  >
    <p class="local-detail reveal">{localDetail}</p>
  </Chapter>

  <Chapter
    num="02"
    label="Service tiers"
    titleHtml="Pick your <em>tier</em>."
    id="tiers"
  >
    <ul class="tier-grid reveal-stagger">
      {tiers.map((t) => (
        <li>
          <a class="tier-link" href={t.href}>
            <span class="tier-link-name">{t.estimate.label}</span>
            <span class="tier-link-meta">{t.estimate.hoursLabel} · {t.estimate.rangeLabel}</span>
            <span class="tier-link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="03"
    label="Nearby"
    titleHtml="Across the <em>region</em>."
    id="nearby"
  >
    <ul class="nearby-grid reveal-stagger">
      {nearbyCities.map((c) => (
        <li>
          <a class="nearby-link" href={c.href}>
            <em>{c.name}</em>
            <span class="nearby-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Chapter>

  <Trust num="04" />
  <FinalCTA num="05" />
</Base>

<style>
  .local-detail {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }

  .tier-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
  .tier-grid li:nth-last-child(-n+2) .tier-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .tier-grid li:not(:last-child) .tier-link { border-bottom: none; }
    .tier-grid li:last-child .tier-link { border-bottom: 1px solid var(--line); }
  }

  .tier-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .tier-link:hover { padding-left: 1rem; }

  .tier-link-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .tier-link-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-2);
    letter-spacing: 0.06em;
  }
  .tier-link-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .tier-link:hover .tier-link-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .nearby-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .nearby-grid { grid-template-columns: 1fr; }
  }
  .nearby-grid li:nth-last-child(-n+2) .nearby-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .nearby-grid li:not(:last-child) .nearby-link { border-bottom: none; }
    .nearby-grid li:last-child .nearby-link { border-bottom: 1px solid var(--line); }
  }

  .nearby-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .nearby-link em {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-style: italic;
    letter-spacing: -0.02em;
    transition: color 400ms var(--ease);
  }
  .nearby-link:hover { padding-left: 1rem; }
  .nearby-link:hover em { color: var(--accent); }
  .nearby-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .nearby-link:hover .nearby-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }
</style>
