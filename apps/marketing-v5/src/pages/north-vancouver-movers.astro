---
// /north-vancouver-movers — fourth city page in E8. Same shape as
// the prior city pages.
//
// Photo: hero-van.png reused.
//
// Logistics fact chosen: option (a) — bridge crossings. North
// Vancouver is the only city in the 8 whose moves almost always
// begin or end with a bridge crossing (Lions Gate or Iron Workers
// Memorial). The bridge-routing-by-time-of-day operational reality
// frames the OPENING sentence and is the page's defining fact.
// Hillside-driveway grading (option b) is folded in near the end as
// a secondary operational detail; intra-North-Shore Deep Cove
// distance (option c) folded into the neighborhood enumeration.
//
// Nearby cities: per Feroz directive, "West Vancouver, Vancouver,
// Burnaby" — three actually-served cities. Stayed at three; user
// allowed 3-4. Coquitlam is reachable via Iron Workers + Hwy 1 but
// further afield, and the geographically-tight three is cleaner.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/north-vancouver-movers';

const city = {
  name: 'North Vancouver',
  neighborhoods: ['Lower Lonsdale', 'Lynn Valley', 'Edgemont Village', 'Deep Cove'],
};

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
const localDetail =
  `North Vancouver sits across Burrard Inlet from the rest of Metro Vancouver, which means every North Van move begins or ends with a bridge crossing — Lions Gate (narrower, height-restricted, sometimes counterflow on the centre lane) or the Iron Workers Memorial (Highway 1, wider but commute-congested by 7:30 a.m. and again at 4 p.m.). We route around the bridges by time of day; an 8 a.m. start with an Iron Workers crossing is a different morning than a 10 a.m. start over Lions Gate. Four neighborhoods worth naming: Lower Lonsdale (LoLo), the urban heart on the SeaBus side, with mid-rise condos and a few newer towers — freight-elevator coordination here is straightforward but the loading-bay alley is shared with restaurants, and we time around their delivery windows; Lynn Valley, deep into the trees with detached homes set back from the street and longer carries from curb to door; Edgemont Village, character single-family on narrow heritage streets where the truck stages at the corner more often than the driveway; Deep Cove on the eastern water, more geographically isolated and the longest intra-North-Shore move we handle. Hillside topography on many blocks means some driveways grade too steep for the truck to back up — we stage at street level and carry. Most North Van moves run four to seven hours; the bridge time is part of the hourly bill, and the quote we send already accounts for it; target overage under ${overageThreshold}%.`;

const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tiers = tierSlugs.map((slug) => ({
  estimate: tierEstimate(slug),
  href: `/${slug}-movers`,
}));

// Per directive: West Vancouver (adjacent west on the North Shore),
// Vancouver (across Lions Gate / SeaBus), Burnaby (via Iron Workers).
// All three are in the 8-city service area.
const nearbyCities = [
  { name: 'West Vancouver', href: '/west-vancouver-movers' },
  { name: 'Vancouver', href: '/vancouver-movers' },
  { name: 'Burnaby', href: '/burnaby-movers' },
];

const title = 'Movers in North Vancouver — Inlet Move Co.';
const description = `Local moves across North Vancouver — Lower Lonsdale, Lynn Valley, Edgemont Village, Deep Cove. Two movers + cargo van, $${PRICING.rates.hourlyRate}/hr, same-week availability across the North Shore.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Service area', item: `${SITE}/service-area` },
    { '@type': 'ListItem', position: 3, name: city.name, item: `${SITE}${PATH}` },
  ],
};

const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  '@id': `${SITE}${PATH}#business`,
  name: `Inlet Move Co. — ${city.name}`,
  url: `${SITE}${PATH}`,
  parentOrganization: { '@id': `${SITE}/#organization` },
  description: `Local moving company serving ${city.name}, BC. Two movers + cargo van, hourly billing from $${PRICING.rates.hourlyRate}/hr, same-week local moves across the North Shore.`,
  areaServed: { '@type': 'City', name: `${city.name}, BC, Canada` },
  knowsLanguage: ['en'],
  ...(PRICING.phone.active ? { telephone: PRICING.phone.tel } : {}),
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: PRICING.links.quote,
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
      ],
    },
    result: { '@type': 'Reservation', name: 'Moving quote request' },
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, cityBusinessSchema]}
>
  <CityHero
    city={city.name}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a North Vancouver hillside street, golden-hour afternoon"
    neighborhoods={city.neighborhoods.join(' · ')}
    h1Html={`Movers in <em>${city.name}</em>.`}
    intro={`Same-week local moves across ${city.name}.`}
  />

  <Chapter
    num="01"
    label="Local detail"
    titleHtml={`${city.name}, in <em>particular</em>.`}
    id="local-detail"
  >
    <p class="local-detail reveal">{localDetail}</p>
  </Chapter>

  <Chapter
    num="02"
    label="Service tiers"
    titleHtml="Pick your <em>tier</em>."
    id="tiers"
  >
    <ul class="tier-grid reveal-stagger">
      {tiers.map((t) => (
        <li>
          <a class="tier-link" href={t.href}>
            <span class="tier-link-name">{t.estimate.label}</span>
            <span class="tier-link-meta">{t.estimate.hoursLabel} · {t.estimate.rangeLabel}</span>
            <span class="tier-link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="03"
    label="Nearby"
    titleHtml="Across the <em>region</em>."
    id="nearby"
  >
    <ul class="nearby-grid reveal-stagger">
      {nearbyCities.map((c) => (
        <li>
          <a class="nearby-link" href={c.href}>
            <em>{c.name}</em>
            <span class="nearby-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Chapter>

  <Trust num="04" />
  <FinalCTA num="05" />
</Base>

<style>
  .local-detail {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }

  .tier-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
  .tier-grid li:nth-last-child(-n+2) .tier-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .tier-grid li:not(:last-child) .tier-link { border-bottom: none; }
    .tier-grid li:last-child .tier-link { border-bottom: 1px solid var(--line); }
  }

  .tier-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .tier-link:hover { padding-left: 1rem; }

  .tier-link-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .tier-link-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-2);
    letter-spacing: 0.06em;
  }
  .tier-link-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .tier-link:hover .tier-link-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .nearby-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .nearby-grid { grid-template-columns: 1fr; }
  }
  .nearby-grid li:nth-last-child(-n+2) .nearby-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .nearby-grid li:not(:last-child) .nearby-link { border-bottom: none; }
    .nearby-grid li:last-child .nearby-link { border-bottom: 1px solid var(--line); }
  }

  .nearby-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .nearby-link em {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-style: italic;
    letter-spacing: -0.02em;
    transition: color 400ms var(--ease);
  }
  .nearby-link:hover { padding-left: 1rem; }
  .nearby-link:hover em { color: var(--accent); }
  .nearby-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .nearby-link:hover .nearby-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }
</style>
