---
// /3-bedroom-movers — service-tier page (3 of 5 remaining tier pages in E7).
// Same TierHero + Chapter + Trust + FinalCTA scaffold as /studio-movers,
// /1-bedroom-movers, and /2-bedroom-movers. Variations: tier-specific
// TierHero intro reflecting the largest residential tier (full homes,
// townhouses, larger condos with multiple staging zones; heritage home
// stair/doorway constraints; customer self-disconnects appliances;
// honest two-trip allowance with one van), include-grid items 3 and 4
// retuned for 3-bedroom operational reality — tier-scaled documentation
// framing, and "Multi-zone moves · House to house" replacing prior
// tiers' lobby-meet / stairwell-paths.
//
// Photo: clipboard.png — itemized invoice shot. Pre-flight measured
// the q=82 768w webp at 66 KB (well under the 70 KB safe threshold;
// studio's hero-van transfers at 64 KB and scores 95 mobile). Default
// heroQuality applies; no calibration override needed.
//
// Photo rationale tied to copy: longer moves generate more line-items
// and customers care more about the math. The TierHero subtitle leans
// into this with "the longer the move, the more the itemized billing
// matters" — pairs naturally with the clipboard image.

import Base from '../layouts/Base.astro';
import TierHero from '../components/sections/TierHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, quoteUrlAbsolute } from '../lib/pricing';
import clipboard from '../assets/clipboard.png';

const tier = tierEstimate('3-bedroom');
const SITE = 'https://inletmove.ca';
const PATH = '/3-bedroom-movers';

const title = `3+ bedroom home movers in Metro Vancouver — Inlet Move`;
const description =
  `Two movers + cargo van. ${tier.label} moves typically take ${tier.hoursLow}–${tier.hoursHigh} hours, ${tier.rangeLabel} total. Same-week local moves across Metro Vancouver.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE}/services` },
    { '@type': 'ListItem', position: 3, name: '3+ bedroom movers', item: `${SITE}${PATH}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE}${PATH}#service`,
  name: '3+ bedroom home move',
  serviceType: 'Local moving service',
  category: 'Residential moving',
  description:
    `${tier.label} home moves with a two-mover crew + cargo van. ${tier.hoursLabel} typical, ${tier.rangeLabel} total. Hourly billing, photo-documented, no fuel or stair surcharges. Common Metro Vancouver scenario: Kitsilano heritage home with stairs, narrow doorways, and a basement suite to clear separately.`,
  provider: { '@id': `${SITE}/#business` },
  areaServed: { '@type': 'AdministrativeArea', name: 'Metro Vancouver, BC, Canada' },
  url: `${SITE}${PATH}`,
  offers: {
    '@type': 'Offer',
    name: '3+ bedroom home move',
    priceCurrency: PRICING.currency,
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: tier.priceLow,
      maxPrice: tier.priceHigh,
      priceCurrency: PRICING.currency,
      unitText: 'per move',
    },
    availability: 'https://schema.org/InStock',
    url: quoteUrlAbsolute(),
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, serviceSchema]}
>
  <TierHero
    tier={tier}
    photo={clipboard}
    photoAlt="Inlet Move itemized clipboard invoice from a multi-room Vancouver home move, line-by-line billing"
    h1Html="3+ bedroom home <em>movers</em>."
    intro="The largest moves we handle — full homes, townhouses, larger condos. Three, four, five-plus bedrooms under one tier, and the 26ft box truck steps in here so the load fits in fewer trips. Usually a single-family house with three or four staging zones (basement, garage, sometimes an attic), often a heritage home in Kitsilano or Mt Pleasant where doorways are narrow and stairs are steep. Customers self-disconnect appliances; we don't plumb or rewire. Very full homes occasionally still need two trips — the 7–10 hour estimate is honest about that, not an upsell. May through October fills first. Same crew, same rate, same care — the move is just longer."
  />

  <Chapter
    num="01"
    label="What's included"
    titleHtml={`${tier.hoursLabel}.<br /><em>${tier.rangeLabel}</em> total.`}
    id="includes"
  >
    <div class="includes-grid reveal-stagger">
      <div class="include-item">
        <div class="label">Hourly rate</div>
        <div class="value">from ${PRICING.rates.hourlyRate}<em>/hr</em></div>
        <div class="footnote">Two movers + cargo van. ${PRICING.rates.minimumCharge} minimum ({PRICING.rates.minimumHours} hours). Rate depends on vehicle and type of move.</div>
      </div>
      <div class="include-item">
        <div class="label">Quote = bill</div>
        <div class="value">No <em>surprises</em></div>
        <div class="footnote">Target overage under {Math.ceil(PRICING.claims.overagePercent)}%. No fuel, stair, or weekend fees.</div>
      </div>
      <div class="include-item">
        <div class="label">Photo documentation</div>
        <div class="value"><em>Same</em> archive</div>
        <div class="footnote">Every room, every fragile item, every staging zone — basement to attic if relevant. The load grows with the tier; the documentation is identical.</div>
      </div>
      <div class="include-item">
        <div class="label">Multi-zone moves</div>
        <div class="value">House to <em>house</em></div>
        <div class="footnote">Standalone homes often mean a basement, a garage, sometimes an attic — three or four staging zones in one move. We sequence the load so heavy pieces from the deepest zone go first, and the kitchen lands at the new house first so the family can settle by dinner.</div>
      </div>
    </div>
    <Terms variant="block" />
  </Chapter>

  <Trust num="02" />
  <FinalCTA num="03" />
</Base>

<style>
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-top: 4rem;
  }
  @media (max-width: 768px) {
    .includes-grid { grid-template-columns: 1fr; }
  }

  .include-item {
    border-top: 1px solid var(--line);
    padding: 1.75rem 2rem 1.75rem 0;
  }
  .include-item .label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .include-item .value {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .include-item .value em {
    font-style: italic;
    color: var(--accent);
  }
  .include-item .footnote {
    font-size: 0.85rem;
    color: var(--fg-2);
    margin-top: 0.5rem;
    max-width: 38ch;
  }
</style>
