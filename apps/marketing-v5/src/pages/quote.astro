---
// /quote — intake form. Customer fills → Web3Forms (api.web3forms.com)
// → leads@inletmove.ca (forwards to hello@) → Feroz monitors.
//
// No backend code on this site. Web3Forms handles the POST, validation,
// hCaptcha, spam filtering, and the success redirect. The form is a
// pure HTML form whose submit action targets Web3Forms. Their loader
// script (https://web3forms.com/client/script.js) wires AJAX submission
// + injects the hCaptcha widget anywhere data-captcha="true" appears.
//
// Sensitive bits in client HTML (by design — Web3Forms uses client-side
// access keys + hCaptcha for spam mitigation):
//   - access_key:        Web3Forms-issued, public by design
//   - hCaptcha sitekey:  Web3Forms shared sitekey (50b2fe65-...) — they
//                        own the secret key on their backend; we just
//                        embed the public sitekey on our forms
//
// Field set matches the 6-tier slug list from pricing.json.tiers and
// the operational fields Inlet needs to quote (origin, destination,
// move size, preferred date, optional notes). Honeypot ('botcheck')
// + hCaptcha + Web3Forms strict spam filter cover the bot vector.
//
// Auto-reply to the customer is NOT available on Web3Forms free tier;
// the success banner on /contact?success=1 communicates what an
// auto-reply email otherwise would (response window, urgent-call
// fallback).

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug, movesHoursLabel } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/quote';

const moveHours = movesHoursLabel();

// Tier options for the move-size <select>. Drives both the visible
// option list and the value submitted to Web3Forms (slug form, matches
// pricing.json.tiers keys for clean lead-routing in MoverOS).
const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tierOptions = tierSlugs.map((slug) => {
  const t = tierEstimate(slug);
  return {
    value: slug,
    label: `${t.label} · ${t.hoursLabel} · ${t.rangeLabel}`,
  };
});

const title = 'Tell us about your move — Inlet Move Co.';
const description = `60-second quote intake form. Two movers + cargo van, from $${PRICING.rates.hourlyRate}/hr. We respond within an hour during dispatch hours (${moveHours}). Same-week local moves across Metro Vancouver.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Quote', item: `${SITE}${PATH}` },
  ],
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema]}
>
  <CityHero
    city="Quote"
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a Metro Vancouver street, ready for a same-week move"
    h1Html="Tell us about your <em>move</em>."
    intro={`Two movers + cargo van, from $${PRICING.rates.hourlyRate}/hr. We respond within an hour during dispatch hours (${moveHours}). Custom moves quoted at booking.`}
    eyebrowText="[ INTAKE ]  Quote request · Inlet Move Co."
    ctaHref="#form"
  />

  <Chapter
    num="01"
    label="Your move"
    titleHtml="Six fields. <em>One</em> hour."
    id="form"
  >
    <form
      class="intake-form reveal"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input type="hidden" name="access_key" value="538e1517-9f4f-4d1a-93c8-5c84a6f62098" />
      <input type="hidden" name="subject" value="New lead from inletmove.ca" />
      <input type="hidden" name="from_name" value="Inlet Move Co. Lead Form" />
      <input type="hidden" name="redirect" value="https://inletmove.ca/contact?success=1" />
      {/* Honeypot — Web3Forms standard, hidden from real users */}
      <input
        type="checkbox"
        name="botcheck"
        style="display: none;"
        tabindex="-1"
        aria-hidden="true"
      />

      <fieldset>
        <legend>Contact</legend>

        <label class="field">
          <span class="field-label">Your name <em>*</em></span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Full name"
          />
        </label>

        <label class="field">
          <span class="field-label">Phone <em>*</em></span>
          <input
            type="tel"
            name="phone"
            required
            autocomplete="tel"
            placeholder="604 555 0123"
          />
        </label>

        <label class="field">
          <span class="field-label">Email <em>*</em></span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
          />
        </label>
      </fieldset>

      <fieldset>
        <legend>The move</legend>

        <label class="field">
          <span class="field-label">Moving from <em>*</em></span>
          <input
            type="text"
            name="moving_from"
            required
            autocomplete="street-address"
            placeholder="Street address, city"
          />
        </label>

        <label class="field">
          <span class="field-label">Moving to <em>*</em></span>
          <input
            type="text"
            name="moving_to"
            required
            placeholder="Street address, city"
          />
        </label>

        <label class="field">
          <span class="field-label">Move size <em>*</em></span>
          <select name="move_size" required>
            <option value="">Choose tier...</option>
            {tierOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </label>

        <label class="field">
          <span class="field-label">Preferred move date <em>*</em></span>
          <input type="date" name="move_date" required />
          <small class="field-help">Earliest date we can quote toward. We'll work with you on actual scheduling.</small>
        </label>

        <label class="field">
          <span class="field-label">Special items or notes</span>
          <textarea
            name="notes"
            rows="4"
            placeholder="Piano, antiques, parking constraints, elevator booking — anything we should know"
          ></textarea>
        </label>
      </fieldset>

      <label class="consent field">
        <input type="checkbox" name="consent" required />
        <span>I consent to being contacted by Inlet Move Co. about my move. See <a href="/privacy" class="inline-link">Privacy Policy</a>.</span>
      </label>

      {/* hCaptcha — Web3Forms shared sitekey. Their loader script
          (loaded below) injects the widget here automatically. */}
      <div
        class="h-captcha"
        data-captcha="true"
        data-sitekey="50b2fe65-b00b-4b9e-ad62-3ba471098be2"
      ></div>

      <button type="submit" class="cta-button cta-button--large magnetic">
        Send request
        <span class="arrow">→</span>
      </button>
    </form>

    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="02"
    label="What happens next"
    titleHtml="On time. <em>On</em> quote."
    id="next"
  >
    <p class="next-prose reveal">
      We'll review your request and respond within an hour during dispatch
      hours ({moveHours}). For urgent moves call {PRICING.phone.active && (
        <a href={`tel:${PRICING.phone.tel}`} class="inline-link">{PRICING.phone.vanity}</a>
      )} directly. Same crew, same rate, same care — our standard is to be
      on time, on quote, and on schedule.
    </p>
  </Chapter>

  <Trust num="03" />
  <FinalCTA num="04" />
</Base>

{/* Web3Forms client script — handles AJAX submission and injects
    the hCaptcha widget where data-captcha="true" is present. Loaded
    once per page. */}
<script is:inline src="https://web3forms.com/client/script.js" async defer></script>

<style>
  .intake-form {
    max-width: 56ch;
    margin: 4rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .intake-form fieldset {
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .intake-form legend {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-3);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding: 0;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .field-label em {
    color: var(--accent);
    font-style: normal;
  }
  .field-help {
    font-size: 0.78rem;
    color: var(--fg-3);
    line-height: 1.45;
    margin-top: 0.25rem;
  }

  .intake-form input[type="text"],
  .intake-form input[type="tel"],
  .intake-form input[type="email"],
  .intake-form input[type="date"],
  .intake-form select,
  .intake-form textarea {
    background: var(--bg-2);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.5;
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 0.75rem 0.95rem;
    width: 100%;
    transition: border-color 250ms var(--ease), background 250ms var(--ease);
    -webkit-appearance: none;
    appearance: none;
  }
  .intake-form input:focus,
  .intake-form select:focus,
  .intake-form textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg);
  }
  .intake-form input::placeholder,
  .intake-form textarea::placeholder {
    color: var(--fg-3);
  }
  .intake-form textarea {
    resize: vertical;
    min-height: 6rem;
    font-family: var(--sans);
  }

  /* date input — strip the awkward Chrome native styling */
  .intake-form input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(0.7);
    cursor: pointer;
  }

  /* select — re-add a chevron after stripping native */
  .intake-form select {
    background-image: linear-gradient(45deg, transparent 50%, var(--fg-2) 50%),
                      linear-gradient(135deg, var(--fg-2) 50%, transparent 50%);
    background-position: calc(100% - 1.25rem) 1.05rem,
                         calc(100% - 0.75rem) 1.05rem;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 2.5rem;
  }

  .consent {
    flex-direction: row;
    align-items: flex-start;
    gap: 0.875rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--fg-2);
  }
  .consent input[type="checkbox"] {
    margin-top: 0.25rem;
    flex-shrink: 0;
    accent-color: var(--accent);
  }
  .consent a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .h-captcha {
    /* hCaptcha widget injected by Web3Forms script. Container needs
       enough room for the iframe (~78px). */
    min-height: 78px;
  }

  .intake-form button[type="submit"] {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .next-prose {
    max-width: 64ch;
    margin: 4rem 0 0;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--fg);
  }
  .next-prose .inline-link {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }
  .next-prose .inline-link:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .intake-form { margin-top: 3rem; gap: 1.75rem; }
    .next-prose { margin-top: 3rem; font-size: 1rem; }
  }
</style>
