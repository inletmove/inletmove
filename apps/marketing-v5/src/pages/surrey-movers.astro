---
// /surrey-movers — third city page in E8. Same shape as
// /vancouver-movers, /burnaby-movers, /richmond-movers.
//
// Photo: hero-van.png reused. City-page photo budget unchanged.
//
// Logistics fact chosen: option (a) — Surrey's geographic scale and
// internal heterogeneity. Embedded as the OPENING sentence and
// re-anchored mid-paragraph by enumerating five distinctly different
// neighborhoods. Option (c) — transit-time visibility — also folded in
// near the end ("Surrey-to-Vancouver moves are the longest local moves
// we book — about 40 km from Cloverdale") because it addresses a real
// customer question that none of the other city pages need to.
//
// Newton mention: factual neighborhood description names the South
// Asian residential-commercial character without operationalizing on
// the demographic — narrow streets and longer carries are the
// operational realities; the demographic is mentioned because it's a
// genuine neighborhood-defining fact (per Feroz directive listing
// "large South Asian commercial-residential population"), not a
// behavioral implication.
//
// Nearby cities: from the 8-city service area lock. Surrey's
// geographic neighbors within Inlet's coverage are New Westminster
// (across Pattullo), Burnaby (via Pattullo + Marine), Coquitlam
// (via Port Mann), Richmond (via Alex Fraser). Four chosen.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/surrey-movers';

const city = {
  name: 'Surrey',
  neighborhoods: ['Newton', 'Guildford', 'Whalley', 'Cloverdale', 'South Surrey'],
};

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
const localDetail =
  `Surrey is the largest city in the 8 by a considerable margin — bigger by area than Vancouver, Burnaby, and New Westminster combined, and so internally varied that a Surrey move on Monday can look operationally nothing like a Surrey move on Tuesday. Five neighborhoods worth naming: Newton, the dense townhouse + walk-up mix along 72nd Avenue and Scott Road, with a substantial South Asian residential-commercial corridor and narrower streets through the older sections — we sometimes park a block off and carry; Guildford, the mall-hub area where high-rises sit alongside 1970s-era detached single-family, with Highway 1 access making it the easiest Surrey neighborhood to reach from Burnaby; Whalley and Surrey Centre, the King George Boulevard tower corridor in rapid densification — recent occupancies, light loads, freight-elevator coordination similar to Metrotown but on a steeper development curve; Cloverdale, where the residential stock thins out toward equestrian properties near the Fairgrounds — longer driveways, sometimes a barn or workshop to clear, no corner-store parking discipline; and South Surrey near the White Rock line, larger lots and more 3-bedroom and multigenerational moves. Surrey-to-Vancouver moves are the longest local moves we book — about 40 km from Cloverdale — so the transit portion of the hourly bill shows clearly on the quote, and we say it upfront. Most Surrey moves run four to eight hours; the rate is the same as anywhere else in Metro Vancouver; the quote we send is the bill you pay; target overage under ${overageThreshold}%.`;

const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tiers = tierSlugs.map((slug) => ({
  estimate: tierEstimate(slug),
  href: `/${slug}-movers`,
}));

const nearbyCities = [
  { name: 'New Westminster', href: '/new-westminster-movers' },
  { name: 'Burnaby', href: '/burnaby-movers' },
  { name: 'Coquitlam', href: '/coquitlam-movers' },
  { name: 'Richmond', href: '/richmond-movers' },
];

const title = 'Movers in Surrey — Inlet Move Co.';
const description = `Local moves across Surrey — Newton, Guildford, Whalley, Cloverdale, South Surrey. Two movers + cargo van, from $${PRICING.rates.hourlyRate}/hr, same-week availability across the city.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Service area', item: `${SITE}/service-area` },
    { '@type': 'ListItem', position: 3, name: city.name, item: `${SITE}${PATH}` },
  ],
};

const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  '@id': `${SITE}${PATH}#business`,
  name: `Inlet Move Co. — ${city.name}`,
  url: `${SITE}${PATH}`,
  parentOrganization: { '@id': `${SITE}/#organization` },
  description: `Local moving company serving ${city.name}, BC. Two movers + cargo van, hourly billing from $${PRICING.rates.hourlyRate}/hr, same-week local moves.`,
  areaServed: { '@type': 'City', name: `${city.name}, BC, Canada` },
  knowsLanguage: ['en'],
  ...(PRICING.phone.active ? { telephone: PRICING.phone.tel } : {}),
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: PRICING.links.quote,
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
      ],
    },
    result: { '@type': 'Reservation', name: 'Moving quote request' },
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, cityBusinessSchema]}
>
  <CityHero
    city={city.name}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a Surrey residential street, golden-hour afternoon"
    neighborhoods={city.neighborhoods.join(' · ')}
    h1Html={`Movers in <em>${city.name}</em>.`}
    intro={`Same-week local moves across ${city.name}.`}
  />

  <Chapter
    num="01"
    label="Local detail"
    titleHtml={`${city.name}, in <em>particular</em>.`}
    id="local-detail"
  >
    <p class="local-detail reveal">{localDetail}</p>
  </Chapter>

  <Chapter
    num="02"
    label="Service tiers"
    titleHtml="Pick your <em>tier</em>."
    id="tiers"
  >
    <ul class="tier-grid reveal-stagger">
      {tiers.map((t) => (
        <li>
          <a class="tier-link" href={t.href}>
            <span class="tier-link-name">{t.estimate.label}</span>
            <span class="tier-link-meta">{t.estimate.hoursLabel} · {t.estimate.rangeLabel}</span>
            <span class="tier-link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="03"
    label="Nearby"
    titleHtml="Across the <em>region</em>."
    id="nearby"
  >
    <ul class="nearby-grid reveal-stagger">
      {nearbyCities.map((c) => (
        <li>
          <a class="nearby-link" href={c.href}>
            <em>{c.name}</em>
            <span class="nearby-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Chapter>

  <Trust num="04" />
  <FinalCTA num="05" />
</Base>

<style>
  .local-detail {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }

  .tier-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
  .tier-grid li:nth-last-child(-n+2) .tier-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .tier-grid li:not(:last-child) .tier-link { border-bottom: none; }
    .tier-grid li:last-child .tier-link { border-bottom: 1px solid var(--line); }
  }

  .tier-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .tier-link:hover { padding-left: 1rem; }

  .tier-link-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .tier-link-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-2);
    letter-spacing: 0.06em;
  }
  .tier-link-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .tier-link:hover .tier-link-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .nearby-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .nearby-grid { grid-template-columns: 1fr; }
  }
  .nearby-grid li:nth-last-child(-n+2) .nearby-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .nearby-grid li:not(:last-child) .nearby-link { border-bottom: none; }
    .nearby-grid li:last-child .nearby-link { border-bottom: 1px solid var(--line); }
  }

  .nearby-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .nearby-link em {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-style: italic;
    letter-spacing: -0.02em;
    transition: color 400ms var(--ease);
  }
  .nearby-link:hover { padding-left: 1rem; }
  .nearby-link:hover em { color: var(--accent); }
  .nearby-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .nearby-link:hover .nearby-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }
</style>
