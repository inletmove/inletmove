---
// /about — the brand explanation page. Honest scope: Inlet is a brand-new
// company (founded 2026) with no operating history claims, no testimonial
// volume, no awards, no founder mythology. The Cognitia/MoverOS/Demandra
// architecture gets explained from the customer's benefit angle, not from
// an org-chart angle.
//
// Reuses CityHero (the broadened sub-page hero) with about-specific
// eyebrow override and no neighborhoods strip. Crew portrait as the hero
// photo per directive — the brand IS the people.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import { PRICING } from '../lib/pricing';
import crewPortrait from '../assets/crew-portrait.png';

const SITE = 'https://inletmove.ca';
const PATH = '/about';

const overageThreshold = Math.ceil(PRICING.claims.overagePercent);

// 'Who we are' — ~170 words. Honest scope (founded 2026, small operation),
// Cognitia/MoverOS/Demandra explained from customer benefit. No founder
// mythology, no operating-volume claims, no awards. Response-time claim
// templates from PRICING.claims so a real-ops calibration propagates.
const whoWeAre =
  `Inlet Move Co. is a Metro Vancouver moving company founded in 2026. Local moves only — the cities listed in the service area, the bridges between them, nothing further. Inlet is one of three brands under Cognitia, alongside MoverOS (the moving-company software) and Demandra (the marketing and operations arm). That matters in two practical ways. First, Inlet uses MoverOS to handle quotes, photo documentation, and crew dispatch, so the same care that goes into the work goes into the paperwork. Second, Demandra runs the customer-facing communication: the quote form, the SMS updates on move day, the follow-ups. Quotes come back inside an hour, with a target first-text from a real human in ${PRICING.claims.responseTimeMinutes} minutes. Two movers, a branded cargo van for standard moves and a 26ft box truck for the larger ones, from $${PRICING.rates.hourlyRate} an hour, $${PRICING.rates.minimumCharge} minimum — that is the whole company. The rate depends on the vehicle and type of move; we confirm before booking. Trained, vetted, introduced by name on move day. Background-checked, reference-checked, hired directly by Inlet — no anonymous subcontractors, no franchise paperwork between you and the people lifting your sofa.`;

// 'How we work' — 142 words. Operational philosophy, all values templated
// from PRICING + trustCopy()-aligned thresholds. Honest non-coverage at
// the end (no Whistler, no inter-address storage) matching /service-area
// scope discipline.
const howWeWork =
  `Hourly billing, line-by-line. The clock starts when we arrive at your address and stops when the truck doors close at the destination. Every job is photo-documented: fragile items, before-and-after rooms, the load-out and the load-in. Photos are archived for the duration of any insurance claim window. The quote we send is the bill you pay, with target overage under ${overageThreshold}%; if the move runs short, the rate runs short with it. No fuel surcharge, no stair fee, no weekend upcharge, no per-item heavy-piece fee. We do not move outside Metro Vancouver and we do not store goods between addresses — we are a local-moves company, full stop. If your move needs either, we will tell you the same week and point you to someone who does.`;

const title = 'About Inlet Move Co. — Metro Vancouver moving';
const description = `Inlet is a small Metro Vancouver moving company founded in 2026. Local moves only, hourly billing from $${PRICING.rates.hourlyRate}/hr, photo-documented every job, branded crew introduced by name.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE}${PATH}` },
  ],
};

// AboutPage is a schema.org WebPage subtype. Points mainEntity at the
// global Organization @id so AI agents and Google can resolve "this is
// the about page for that org".
const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${SITE}${PATH}#webpage`,
  url: `${SITE}${PATH}`,
  name: title,
  description,
  inLanguage: 'en-CA',
  isPartOf: { '@id': `${SITE}/#website` },
  mainEntity: { '@id': `${SITE}/#organization` },
  primaryImageOfPage: `${SITE}/assets/og-image.webp`,
  dateModified: new Date().toISOString(),
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, aboutPageSchema]}
>
  <CityHero
    city="About"
    photo={crewPortrait}
    photoAlt="Inlet Move crew beside the cargo van"
    h1Html="About Inlet <em>Move</em>."
    intro="A small Metro Vancouver moving company, on purpose."
    eyebrowText="[ ABOUT ]  Inlet Move Co."
  />

  <Chapter
    num="01"
    label="Who we are"
    titleHtml="A small <em>company</em>, on purpose."
    id="who"
  >
    <p class="about-prose reveal">{whoWeAre}</p>
  </Chapter>

  <Chapter
    num="02"
    label="How we work"
    titleHtml="<em>Hourly</em>, photo-documented."
    id="how"
  >
    <p class="about-prose reveal">{howWeWork}</p>
  </Chapter>

  <Trust num="03" />
  <FinalCTA num="04" />
</Base>

<style>
  .about-prose {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }
</style>
