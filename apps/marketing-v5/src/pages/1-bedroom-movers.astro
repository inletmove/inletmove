---
// /1-bedroom-movers — service-tier page (2 of 5 remaining tier pages in E7).
// Same TierHero + Chapter + Trust + FinalCTA scaffold as /studio-movers and
// /2-bedroom-movers. Variations: tier-specific TierHero intro reflecting the
// volume tier (real bed + sofa + sometimes desk/dining; walk-up vs elevator
// mix; weekends and month-end booking pattern), include-grid items 3 and 4
// retuned for 1-bedroom operational reality — tier-scaled documentation
// framing, and doorway/stairwell geometry replacing studio's lobby-meet
// (which is studio-specific, not the defining challenge at this tier).
//
// Photo: sofa-carry.png — speaks to the "sectional through doorway" geometry
// that defines 1-bedroom moves. Visually distinct from heroVan (studio) and
// loadingBoxes (2-bedroom); photo rotation across the tier set.

import Base from '../layouts/Base.astro';
import TierHero from '../components/sections/TierHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate } from '../lib/pricing';
import sofaCarry from '../assets/sofa-carry.png';

const tier = tierEstimate('1-bedroom');
const SITE = 'https://inletmove.ca';
const PATH = '/1-bedroom-movers';

const title = `1-bedroom apartment movers in Metro Vancouver — Inlet Move`;
const description =
  `Two movers + cargo van. ${tier.label} moves typically take ${tier.hoursLow}–${tier.hoursHigh} hours, ${tier.rangeLabel} total. Same-week local moves across Metro Vancouver.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE}/services` },
    { '@type': 'ListItem', position: 3, name: '1-bedroom movers', item: `${SITE}${PATH}` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE}${PATH}#service`,
  name: '1-bedroom apartment move',
  serviceType: 'Local moving service',
  category: 'Residential moving',
  description:
    `${tier.label} apartment moves with a two-mover crew + cargo van. ${tier.hoursLabel} typical, ${tier.rangeLabel} total. Hourly billing, photo-documented, no fuel or stair surcharges. Common Metro Vancouver scenario: Mt Pleasant walk-up with a sectional that needs to come around a tight stairwell turn.`,
  provider: { '@id': `${SITE}/#business` },
  areaServed: { '@type': 'AdministrativeArea', name: 'Metro Vancouver, BC, Canada' },
  url: `${SITE}${PATH}`,
  offers: {
    '@type': 'Offer',
    name: '1-bedroom apartment move',
    priceCurrency: PRICING.currency,
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: tier.priceLow,
      maxPrice: tier.priceHigh,
      priceCurrency: PRICING.currency,
      unitText: 'per move',
    },
    availability: 'https://schema.org/InStock',
    url: PRICING.links.quote,
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, serviceSchema]}
>
  <TierHero
    tier={tier}
    photo={sofaCarry}
    photoAlt="Inlet Move crew carrying a sectional sofa through a Vancouver apartment doorway, a typical 1-bedroom load"
    h1Html="1-bedroom apartment <em>movers</em>."
    intro="The most common move size in Metro Vancouver — a real bed, a sofa, often a desk and a small dining set. Usually an elevator building with a fixed loading-bay window, sometimes a walk-up where the sectional has to come around a stairwell turn the previous tenant clearly never tested. Weekends and month-end book out first."
    heroQuality={75}
  />

  <Chapter
    num="01"
    label="What's included"
    titleHtml={`${tier.hoursLabel}.<br /><em>${tier.rangeLabel}</em> total.`}
    id="includes"
  >
    <div class="includes-grid reveal-stagger">
      <div class="include-item">
        <div class="label">Hourly rate</div>
        <div class="value">${PRICING.rates.hourlyRate}<em>/hr</em></div>
        <div class="footnote">Two movers + cargo van. ${PRICING.rates.minimumCharge} minimum ({PRICING.rates.minimumHours} hours).</div>
      </div>
      <div class="include-item">
        <div class="label">Quote = bill</div>
        <div class="value">No <em>surprises</em></div>
        <div class="footnote">Target overage under {Math.ceil(PRICING.claims.overagePercent)}%. No fuel, stair, or weekend fees.</div>
      </div>
      <div class="include-item">
        <div class="label">Photo documentation</div>
        <div class="value"><em>Same</em> archive</div>
        <div class="footnote">Furniture, fragile items, before-and-after rooms, the lobby load-out. The load grows with the tier; the documentation is identical.</div>
      </div>
      <div class="include-item">
        <div class="label">Doorway geometry</div>
        <div class="value">Stairwell <em>paths</em></div>
        <div class="footnote">Sectional sofas, queen and king mattresses, the occasional desk that needs to turn on its side. We map the path from suite door to van before the load starts.</div>
      </div>
    </div>
    <Terms variant="block" />
  </Chapter>

  <Trust num="02" />
  <FinalCTA num="03" />
</Base>

<style>
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-top: 4rem;
  }
  @media (max-width: 768px) {
    .includes-grid { grid-template-columns: 1fr; }
  }

  .include-item {
    border-top: 1px solid var(--line);
    padding: 1.75rem 2rem 1.75rem 0;
  }
  .include-item .label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .include-item .value {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .include-item .value em {
    font-style: italic;
    color: var(--accent);
  }
  .include-item .footnote {
    font-size: 0.85rem;
    color: var(--fg-2);
    margin-top: 0.5rem;
    max-width: 38ch;
  }
</style>
