---
// /vancouver-movers — city-template-defining page. The other 7 city pages
// (E8) reuse this same shape (CityHero + 3 Chapters + Trust + FinalCTA)
// with their own 200-word local-detail prose. The defining requirement
// per directive: each city page's intro must NOT survive a find-replace
// of city names while still reading correctly.
//
// BreadcrumbList chains through /service-area (built next at E2c). The
// /service-area path resolves correctly once that page lands; until then
// it's a soft 404 in dev which the smoke test tolerates.

import Base from '../layouts/Base.astro';
import CityHero from '../components/sections/CityHero.astro';
import Chapter from '../components/sections/Chapter.astro';
import Trust from '../components/sections/Trust.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Terms from '../components/shared/Terms.astro';
import { PRICING, tierEstimate, type TierSlug } from '../lib/pricing';
import heroVan from '../assets/hero-van.png';

const SITE = 'https://inletmove.ca';
const PATH = '/vancouver-movers';

const city = {
  name: 'Vancouver',
  neighborhoods: ['Downtown', 'West End', 'Mt Pleasant', 'Kitsilano', 'East Van'],
};

// ~220-word local-detail paragraph. Editorial Aesop tone, real specificity,
// honest scope (no claims of history or volume Inlet doesn't have yet).
// `${overageThreshold}%` derives from PRICING.claims.overagePercent so a
// real-ops calibration in pricing.json updates this prose on next build.
const overageThreshold = Math.ceil(PRICING.claims.overagePercent);
const localDetail =
  `Vancouver is the city Inlet is built around. Five neighborhoods worth naming by their physical realities: Downtown's high-rises, where freight-elevator bookings need at least twenty-four hours' notice and often a refundable deposit; the West End's three-storey walk-ups, where a sectional sofa comes down the stairs at the right angle or doesn't come down at all; Mt Pleasant's heritage homes along Main and Kingsway, half of them with basement suites and street-side parking only; Kitsilano's blend of newer strata towers and pre-war walk-ups along 4th Avenue; East Van's Vancouver Specials, those split-level postwar houses with the carport on one side and the main entry up six steps. The City of Vancouver requires a permit for moving trucks to park on residential streets, filed forty-eight to seventy-two hours ahead — we file it on your behalf as soon as the date is confirmed, because nobody wants to discover at 8 a.m. that the truck has to live in the alley two blocks away. Most local Vancouver moves run four to seven hours: walk-ups slower for the stairs, high-rises slower for the elevator wait. The rate is the same in either case, and the quote we send is the bill you pay, with target overage under ${overageThreshold}%.`;

// Tier link grid — same 6 tiers as /services, formatted compact for the
// city page's hub-and-spoke role. Uses tierEstimate() for live price math.
const tierSlugs: TierSlug[] = [
  'studio',
  '1-bedroom',
  '2-bedroom',
  '3-bedroom',
  'multigenerational',
  'senior-downsizing',
];
const tiers = tierSlugs.map((slug) => ({
  estimate: tierEstimate(slug),
  href: `/${slug}-movers`,
}));

// Geographic-neighbour cross-links for SEO + UX. Vancouver's immediate
// neighbours are Burnaby (east), Richmond (south, via tunnel), North
// Vancouver (north shore), West Vancouver (further north shore).
const nearbyCities = [
  { name: 'Burnaby', href: '/burnaby-movers' },
  { name: 'Richmond', href: '/richmond-movers' },
  { name: 'North Vancouver', href: '/north-vancouver-movers' },
  { name: 'West Vancouver', href: '/west-vancouver-movers' },
];

const title = 'Movers in Vancouver — Inlet Move Co.';
const description = `Local moves across Vancouver — Downtown, West End, Mt Pleasant, Kitsilano, East Van. Two movers + cargo van, $${PRICING.rates.hourlyRate}/hr, same-week availability across the city.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Service area',
      item: `${SITE}/service-area`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: city.name,
      item: `${SITE}${PATH}`,
    },
  ],
};

// City-scoped MovingCompany schema, areaServed narrowed to Vancouver.
// parentOrganization references the global Organization @id from
// StructuredData.astro so Google understands this is the same company
// operating in this specific city, not a separate entity.
const cityBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  '@id': `${SITE}${PATH}#business`,
  name: `Inlet Move Co. — ${city.name}`,
  url: `${SITE}${PATH}`,
  parentOrganization: { '@id': `${SITE}/#organization` },
  description: `Local moving company serving ${city.name}, BC. Two movers + cargo van, hourly billing from $${PRICING.rates.hourlyRate}/hr, same-week local moves.`,
  areaServed: { '@type': 'City', name: `${city.name}, BC, Canada` },
  knowsLanguage: ['en'],
  ...(PRICING.phone.active ? { telephone: PRICING.phone.tel } : {}),
  potentialAction: {
    '@type': 'ReserveAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: PRICING.links.quote,
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
      ],
    },
    result: { '@type': 'Reservation', name: 'Moving quote request' },
  },
};
---

<Base
  title={title}
  description={description}
  canonicalPath={PATH}
  ogType="website"
  extraSchema={[breadcrumbSchema, cityBusinessSchema]}
>
  <CityHero
    city={city.name}
    photo={heroVan}
    photoAlt="Inlet Move cargo van on a Vancouver residential street, golden-hour afternoon"
    neighborhoods={city.neighborhoods.join(' · ')}
    h1Html={`Movers in <em>${city.name}</em>.`}
    intro={`Same-week local moves across ${city.name}.`}
  />

  <Chapter
    num="01"
    label="Local detail"
    titleHtml={`${city.name}, in <em>particular</em>.`}
    id="local-detail"
  >
    <p class="local-detail reveal">{localDetail}</p>
  </Chapter>

  <Chapter
    num="02"
    label="Service tiers"
    titleHtml="Pick your <em>tier</em>."
    id="tiers"
  >
    <ul class="tier-grid reveal-stagger">
      {tiers.map((t) => (
        <li>
          <a class="tier-link" href={t.href}>
            <span class="tier-link-name">{t.estimate.label}</span>
            <span class="tier-link-meta">{t.estimate.hoursLabel} · {t.estimate.rangeLabel}</span>
            <span class="tier-link-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
    <Terms variant="block" />
  </Chapter>

  <Chapter
    num="03"
    label="Nearby"
    titleHtml="Across the <em>region</em>."
    id="nearby"
  >
    <ul class="nearby-grid reveal-stagger">
      {nearbyCities.map((c) => (
        <li>
          <a class="nearby-link" href={c.href}>
            <em>{c.name}</em>
            <span class="nearby-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </Chapter>

  <Trust num="04" />
  <FinalCTA num="05" />
</Base>

<style>
  .local-detail {
    max-width: 68ch;
    margin: 4rem 0 0;
    font-size: 1.15rem;
    color: var(--fg);
    line-height: 1.7;
  }

  .tier-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
  .tier-grid li:nth-last-child(-n+2) .tier-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .tier-grid li:not(:last-child) .tier-link { border-bottom: none; }
    .tier-grid li:last-child .tier-link { border-bottom: 1px solid var(--line); }
  }

  .tier-link {
    display: grid;
    grid-template-columns: 1.4fr 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .tier-link:hover { padding-left: 1rem; }

  .tier-link-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .tier-link-meta {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--fg-2);
    letter-spacing: 0.06em;
  }
  .tier-link-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .tier-link:hover .tier-link-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }

  .nearby-grid {
    list-style: none;
    margin: 4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (max-width: 768px) {
    .nearby-grid { grid-template-columns: 1fr; }
  }
  .nearby-grid li:nth-last-child(-n+2) .nearby-link {
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 768px) {
    .nearby-grid li:not(:last-child) .nearby-link { border-bottom: none; }
    .nearby-grid li:last-child .nearby-link { border-bottom: 1px solid var(--line); }
  }

  .nearby-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding: 1.5rem 1.25rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    transition: padding 500ms var(--ease);
  }
  .nearby-link em {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    font-style: italic;
    letter-spacing: -0.02em;
    transition: color 400ms var(--ease);
  }
  .nearby-link:hover { padding-left: 1rem; }
  .nearby-link:hover em { color: var(--accent); }
  .nearby-arrow {
    font-family: var(--serif);
    font-style: italic;
    color: var(--fg-3);
    transition: transform 500ms var(--ease), color 500ms var(--ease);
  }
  .nearby-link:hover .nearby-arrow {
    transform: translateX(6px);
    color: var(--accent);
  }
</style>
