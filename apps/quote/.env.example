# ============================================================
# Inlet Move Co. — environment template
# Copy to .env.local for local dev. Never commit .env.local.
# ============================================================

# --- Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (project: inletmove-prod, region: us-west-1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio (lead-inbound SMS to Feroz)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FEROZ_NOTIFY_PHONE=

# --- Resend (lead confirmation email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@inletmove.com

# --- Google Places (address autocomplete in /quote)
GOOGLE_PLACES_API_KEY=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# --- Mapbox (deferred to Week 3 — token reserved)
NEXT_PUBLIC_MAPBOX_TOKEN=
