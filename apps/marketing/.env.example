# Inlet Move marketing site (Astro) — public env vars (PUBLIC_ prefix is exposed to client)

# The URL the quote form POSTs to. In v1, this is the Hostinger PHP shim.
# In v1.1, swap to https://quote.inletmove.com/api/quote (Vercel/Next).
# That swap is a one-env-var change — the form code stays identical.
PUBLIC_QUOTE_ENDPOINT=/quote-handler.php

# Live booking feed URL. v1: empty (component falls back to seed data).
# v1.1: https://quote.inletmove.com/api/feed
PUBLIC_FEED_URL=

# Site URL (must match astro.config.mjs site:)
PUBLIC_SITE_URL=https://inletmove.com
