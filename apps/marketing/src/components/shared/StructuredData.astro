---
interface Props {
  extraSchema?: unknown[];
}

const { extraSchema = [] } = Astro.props;

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  name: 'Inlet Move Co.',
  url: 'https://inletmove.ca',
  description:
    'Local moving company in Metro Vancouver, British Columbia. Same-week local moves. From $150/hr, $300 minimum.',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Vancouver',
    addressRegion: 'BC',
    addressCountry: 'CA',
  },
  areaServed: [
    { '@type': 'City', name: 'Vancouver' },
    { '@type': 'City', name: 'Burnaby' },
    { '@type': 'City', name: 'Richmond' },
    { '@type': 'City', name: 'Surrey' },
    { '@type': 'City', name: 'North Vancouver' },
    { '@type': 'City', name: 'West Vancouver' },
    { '@type': 'City', name: 'Coquitlam' },
    { '@type': 'City', name: 'New Westminster' },
  ],
  openingHours: 'Mo-Su 08:00-20:00',
  knowsLanguage: ['en', 'zh', 'pa', 'hi'],
  sameAs: [],
};
---

<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
{
  extraSchema.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
