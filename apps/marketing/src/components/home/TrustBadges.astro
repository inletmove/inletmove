---
type Badge = {
  key: string;
  title: string;
  value: string;
  verifyHref?: string;
  pending: boolean;
};

const BADGES: Badge[] = [
  {
    key: 'bc_reg',
    title: 'BC Registered',
    value: 'Reg # [Pending verification]',
    pending: true,
  },
  {
    key: 'wcb',
    title: 'WorkSafeBC',
    value: 'Clearance active',
    verifyHref: 'https://online.worksafebc.com/clearancepermission/',
    pending: false,
  },
  {
    key: 'insured',
    title: 'Insured',
    value: '$2M cargo + liability',
    pending: true,
  },
  {
    key: 'gst',
    title: 'GST Registered',
    value: 'GST # [Pending verification]',
    pending: true,
  },
];
---

<section aria-label="Verified" class="bg-bone px-6 py-20 md:px-8 md:py-24">
  <div class="mx-auto max-w-container">
    <div class="mb-10 max-w-2xl">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-pacific">Verified</p>
      <h2
        class="font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
      >
        The boring stuff,
        <em class="display-italic text-pacific">all in order.</em>
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4" data-stagger-root>
      {
        BADGES.map((b, i) => (
          <div
            class="trust-badge group flex items-start gap-4 rounded-xl border border-line-light bg-paper p-6"
            style={`--stagger:${i * 80}ms;`}
          >
            <div
              aria-hidden
              class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-md bg-pacific/10 text-pacific"
            >
              <span class="font-display text-xl font-medium display-soft">✓</span>
            </div>
            <div class="flex-1">
              <h3 class="mb-1 font-body text-sm font-semibold text-inlet-navy">{b.title}</h3>
              <p class:list={['font-mono text-xs', b.pending ? 'text-amber' : 'text-graphite']}>
                {b.value}
              </p>
              {b.verifyHref && (
                <a
                  href={b.verifyHref}
                  target="_blank"
                  rel="noreferrer"
                  class="mt-1.5 inline-block font-body text-xs text-pacific underline-offset-4 hover:underline"
                >
                  Verify &rarr;
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-6 font-mono text-[0.7rem] text-mist-dim">
      Pending values are filled in by Feroz before public launch (week 3).
    </p>
  </div>
</section>

<style>
  .trust-badge {
    opacity: 0;
    transform: translateY(14px);
  }
  .trust-badge.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms),
                transform 600ms cubic-bezier(0.16, 1, 0.3, 1) var(--stagger, 0ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .trust-badge { opacity: 1; transform: none; }
  }
</style>

<script>
  // Stagger-reveal trust badges when the section enters the viewport.
  // Vanilla IO; respects reduced motion via the `is-visible` class.
  const root = document.querySelector<HTMLElement>('[data-stagger-root]');
  if (root) {
    const cards = root.querySelectorAll<HTMLElement>('.trust-badge');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      cards.forEach((c) => c.classList.add('is-visible'));
    } else {
      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              cards.forEach((c) => c.classList.add('is-visible'));
              obs.disconnect();
            }
          }
        },
        { rootMargin: '-15%' },
      );
      obs.observe(root);
    }
  }
</script>
