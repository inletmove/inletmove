---
import ShimmerButton from '../effects/ShimmerButton.astro';
---

<section
  aria-label="Ready to move?"
  class="relative overflow-hidden bg-paper px-6 py-24 md:px-8 md:py-32"
>
  <div
    aria-hidden
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(231, 111, 81, 0.10), transparent 70%), radial-gradient(ellipse 50% 40% at 50% 0%, rgba(31, 122, 140, 0.06), transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <h2
      class="mb-4 font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
    >
      Ready to <em class="display-italic text-ember">move?</em>
    </h2>
    <p class="mb-10 font-body text-lg leading-relaxed text-graphite">
      Quote in 60 seconds. Real human follow-up within the hour.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <ShimmerButton href="/quote" label="Get my quote" ariaLabel="Get my quote in 60 seconds">
        Get my quote <span aria-hidden>&rarr;</span>
      </ShimmerButton>
      <a
        href="tel:6040000000"
        class="inline-flex items-center gap-2 rounded-md border border-line-mid bg-paper px-7 py-3.5 font-body text-base font-semibold text-inlet-navy transition hover:bg-bone-warm"
      >
        <span aria-hidden>📞</span> (604) 000-0000
      </a>
    </div>
  </div>
</section>
