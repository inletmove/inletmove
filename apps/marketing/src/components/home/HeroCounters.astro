---
/**
 * Hero counters — pure presentational, no interactivity, ships zero JS.
 *
 * Honesty contracts (CLAUDE.md §6, brief §6):
 * - 11 min, 4.1%, 98% are aspirational targets — Inlet Move has no
 *   measured operating history yet at launch. Labeled "Target" so the
 *   framing is unambiguous.
 * - $150/hr / $300 min is the real published price.
 */

const COUNTERS = [
  { value: '11', unit: 'min', label: 'Target response' },
  { value: '4.1', unit: '%', label: 'Target overage on quote' },
  { value: '98', unit: '%', label: 'Target on-time arrivals' },
  { value: '$150', unit: '/hr', label: '$300 minimum' },
];
---

<div
  class="grid grid-cols-2 gap-x-8 gap-y-4 border-t border-line-dark pt-6 sm:flex sm:flex-wrap sm:gap-x-10 sm:gap-y-3"
>
  {
    COUNTERS.map((c) => (
      <div class="flex flex-col gap-0.5">
        <div class="font-display text-[1.75rem] font-medium leading-none tabular-nums tracking-tight text-bone display-soft">
          {c.value}
          <span class="font-display text-[0.7em] italic text-ember display-italic">
            {c.unit}
          </span>
        </div>
        <div class="font-mono text-[0.6875rem] uppercase tracking-widest text-mist-dim">
          {c.label}
        </div>
      </div>
    ))
  }
</div>
