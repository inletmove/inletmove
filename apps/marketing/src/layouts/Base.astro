---
import '../styles/global.css';
import StructuredData from '../components/shared/StructuredData.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  /** Optional extra JSON-LD blocks (FAQ, BreadcrumbList, etc.) */
  extraSchema?: unknown[];
}

const {
  title,
  description,
  ogImage = '/og/default.jpg',
  noIndex = false,
  extraSchema = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://inletmove.com').toString();
const ogImageURL = new URL(ogImage, Astro.site ?? 'https://inletmove.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta name="theme-color" content="#0E1F36" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Inlet Move Co." />
    <meta property="og:locale" content="en_CA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,400..700,0..100;1,9..144,400..700,0..100&family=Hanken+Grotesk:wght@300..800&family=JetBrains+Mono:wght@400..600&display=swap"
    />

    <StructuredData extraSchema={extraSchema} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot name="nav" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
