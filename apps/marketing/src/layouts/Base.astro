---
import '../styles/global.css';
import StructuredData from '../components/shared/StructuredData.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noIndex?: boolean;
  /** Optional extra JSON-LD blocks (FAQ, BreadcrumbList, etc.) */
  extraSchema?: unknown[];
  /** Suppress the mobile sticky CTA on pages that already are the CTA (e.g. /quote, /thanks). */
  hideStickyCta?: boolean;
}

const {
  title,
  description,
  ogImage = '/og/default.png',
  noIndex = false,
  extraSchema = [],
  hideStickyCta = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://inletmove.ca').toString();
const ogImageURL = new URL(ogImage, Astro.site ?? 'https://inletmove.ca').toString();

// dateModified — emitted both as og meta and as a WebPage JSON-LD block.
// Stamped at build time. Per v3 brief §6.3, freshness signals matter for
// AI citation ranking.
const dateModified = new Date().toISOString();
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: canonical,
  name: title,
  description,
  inLanguage: 'en-CA',
  isPartOf: { '@id': 'https://inletmove.ca/#website' },
  dateModified,
};

const allExtraSchema = [...(extraSchema ?? []), webPageSchema];

import StickyMobileCTA from '../components/shared/StickyMobileCTA.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta name="theme-color" content="#0E1F36" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Inlet Move Co." />
    <meta property="og:locale" content="en_CA" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta property="article:modified_time" content={dateModified} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,400..700,0..100;1,9..144,400..700,0..100&family=Hanken+Grotesk:wght@300..800&family=JetBrains+Mono:wght@400..600&display=swap"
    />

    <StructuredData extraSchema={allExtraSchema} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot name="nav" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
    {!hideStickyCta && <StickyMobileCTA />}

    <script>
      // Universal section-reveal observer. Adds .is-visible to any element
      // with data-section-reveal or data-stagger-section once it crosses
      // ~15% into the viewport. CSS handles the actual animation.
      (() => {
        const targets = document.querySelectorAll<HTMLElement>(
          '[data-section-reveal], [data-stagger-section]',
        );
        if (!targets.length) return;
        const obs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              (e.target as HTMLElement).classList.add('is-visible');
              obs.unobserve(e.target);
            }
          },
          { rootMargin: '-12%' },
        );
        targets.forEach((t) => obs.observe(t));
      })();
    </script>
  </body>
</html>
