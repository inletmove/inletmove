---
import Base from '../layouts/Base.astro';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/footer/Footer.astro';

const title = 'About — Inlet Move Co.';
const description =
  'Inlet Move Co. is a Vancouver-based moving company built on three ideas: honest pricing, careful handling, and complete documentation.';
---

<Base title={title} description={description}>
  <Nav slot="nav" />

  <article class="bg-paper px-6 pb-24 pt-32 md:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-pacific">About</p>
      <h1
        class="mb-8 font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
      >
        Vancouver-based.
        <em class="display-italic text-ember">Built on three ideas.</em>
      </h1>

      <div class="space-y-6 font-body text-lg leading-relaxed text-charcoal">
        <p>
          Inlet Move Co. is a local moving company serving Metro Vancouver. We work in two-mover
          crews with a cargo van, billing by the hour from $150/hr with a $300 minimum.
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Honest pricing
        </h2>
        <p>
          Hourly. Quoted in 60 seconds online. No fuel surcharge, no stair fee, no weekend
          upcharge. Quote = bill, with a target overage under 5%. (Industry typical is around 22%.)
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Careful handling
        </h2>
        <p>
          Wrap and pad on every job. Trained for senior moves, multigenerational moves, and
          cultural and ceremonial items. $2M cargo and liability coverage on every move.
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Complete documentation
        </h2>
        <p>
          Photo records on every job — fragile items, before-and-after, load-out. If anything is
          ever questioned, there is proof. Bodycam ops are in pilot for Q4 2026; live crew
          tracking ships Q3 2026.
        </p>

        <p class="pt-4 text-graphite">
          We are early. Our team is still small. We hire crew with care — trained, vetted, branded,
          introduced by name. If you have a move that needs more than a sofa-and-a-couple-boxes
          kind of attention — a parent downsizing, a multigenerational household, a household
          with religious or ceremonial items — call us. That is why we are here.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap gap-3">
        <a
          href="/quote"
          class="inline-flex items-center gap-2 rounded-md bg-ember px-7 py-3.5 font-body text-base font-semibold text-bone shadow-cta transition-all hover:-translate-y-px hover:bg-ember-warm"
        >
          Get a quote <span aria-hidden>&rarr;</span>
        </a>
        <a
          href="/movers"
          class="inline-flex items-center gap-2 rounded-md border border-line-mid bg-paper px-7 py-3.5 font-body text-base font-semibold text-inlet-navy transition hover:bg-bone-warm"
        >
          See where we work
        </a>
      </div>
    </div>
  </article>

  <section
    aria-labelledby="customer-journey"
    class="border-t border-line-light bg-bone px-6 py-20 md:px-8 md:py-28"
  >
    <div class="mx-auto max-w-container">
      <div class="mb-10 max-w-2xl">
        <p class="mb-3 font-mono text-xs uppercase tracking-widest text-pacific">
          What it feels like
        </p>
        <h2
          id="customer-journey"
          class="font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Five moments of a move
          <em class="display-italic text-ember">done well.</em>
        </h2>
        <p class="mt-4 font-body text-base leading-relaxed text-graphite">
          From the first quote to the last unpacked box. The photos below are
          editorial placeholders — real Vancouver customer photography lands
          Q2 2026, and an AI-illustrated companion sequence drops alongside it.
        </p>
      </div>

      <ol class="grid gap-6 md:grid-cols-3 lg:grid-cols-5">
        {
          [
            { base: '/images/maya/scene-1-form', step: 'Step 1', title: 'Request a quote', desc: 'Open the site, answer six questions, get a number in under a minute.' },
            { base: '/images/maya/scene-2-photo-scan', step: 'Step 2', title: 'Photo scan', desc: 'Walk your home with the camera (Q3 2026). We identify items, estimate volume.' },
            { base: '/images/maya/scene-3-quote-received', step: 'Step 3', title: 'Confirmed', desc: 'A real human follows up within the hour to confirm the date and the crew.' },
            { base: '/images/maya/scene-4-move-day', step: 'Step 4', title: 'Move day', desc: 'Two trained, branded movers arrive in a cargo van. Photo documentation runs throughout.' },
            { base: '/images/maya/scene-5-settled', step: 'Step 5', title: 'Settled', desc: 'Quote = bill, with a target overage under 5%. You unpack, we follow up in 48h.' },
          ].map((scene) => (
            <li class="flex flex-col">
              <picture class="mb-4 block aspect-[4/5] overflow-hidden rounded-lg">
                <source type="image/avif" srcset={`${scene.base}-1280.avif 1280w, ${scene.base}-1920.avif 1920w`} sizes="(min-width: 1024px) 20vw, (min-width: 768px) 33vw, 100vw" />
                <source type="image/webp" srcset={`${scene.base}-1280.webp 1280w, ${scene.base}-1920.webp 1920w`} sizes="(min-width: 1024px) 20vw, (min-width: 768px) 33vw, 100vw" />
                <img
                  src={`${scene.base}-1280.jpg`}
                  srcset={`${scene.base}-1280.jpg 1280w, ${scene.base}-1920.jpg 1920w`}
                  sizes="(min-width: 1024px) 20vw, (min-width: 768px) 33vw, 100vw"
                  alt={`Editorial placeholder photo for "${scene.title}" — AI-generated Maya character lands in a follow-up session.`}
                  width="1280"
                  height="1600"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-700 hover:scale-[1.03]"
                />
              </picture>
              <p class="mb-1 font-mono text-[0.6875rem] uppercase tracking-widest text-pacific">{scene.step}</p>
              <h3 class="mb-2 font-display text-xl font-medium leading-tight tracking-tight text-inlet-navy display-soft">
                {scene.title}
              </h3>
              <p class="font-body text-sm leading-relaxed text-graphite">{scene.desc}</p>
            </li>
          ))
        }
      </ol>

      <p class="mt-8 font-mono text-[0.7rem] text-mist-dim">
        Editorial placeholder photos sourced from Pexels (public CDN, no attribution required).
        Replaced with real customer photography in Q2 2026.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Base>
