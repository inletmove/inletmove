---
import Base from '../layouts/Base.astro';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/footer/Footer.astro';

const title = 'About — Inlet Move Co.';
const description =
  'Inlet Move Co. is a Vancouver-based moving company built on three ideas: honest pricing, careful handling, and complete documentation.';
---

<Base title={title} description={description}>
  <Nav slot="nav" />

  <article class="bg-paper px-6 pb-24 pt-32 md:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-pacific">About</p>
      <h1
        class="mb-8 font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
      >
        Vancouver-based.
        <em class="display-italic text-ember">Built on three ideas.</em>
      </h1>

      <div class="space-y-6 font-body text-lg leading-relaxed text-charcoal">
        <p>
          Inlet Move Co. is a local moving company serving Metro Vancouver. We work in two-mover
          crews with a cargo van, billing by the hour from $150/hr with a $300 minimum.
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Honest pricing
        </h2>
        <p>
          Hourly. Quoted in 60 seconds online. No fuel surcharge, no stair fee, no weekend
          upcharge. Quote = bill, with a target overage under 5%. (Industry typical is around 22%.)
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Careful handling
        </h2>
        <p>
          Wrap and pad on every job. Trained for senior moves, multigenerational moves, and
          cultural and ceremonial items. $2M cargo and liability coverage on every move.
        </p>

        <h2
          class="pt-4 font-display text-2xl font-medium leading-tight tracking-tight text-inlet-navy display-soft"
        >
          Complete documentation
        </h2>
        <p>
          Photo records on every job — fragile items, before-and-after, load-out. If anything is
          ever questioned, there is proof. Bodycam ops are in pilot for Q4 2026; live crew
          tracking ships Q3 2026.
        </p>

        <p class="pt-4 text-graphite">
          We are early. Our team is still small. We hire crew with care — trained, vetted, branded,
          introduced by name. If you have a move that needs more than a sofa-and-a-couple-boxes
          kind of attention — a parent downsizing, a multigenerational household, a household
          with religious or ceremonial items — call us. That is why we are here.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap gap-3">
        <a
          href="/quote"
          class="inline-flex items-center gap-2 rounded-md bg-ember px-7 py-3.5 font-body text-base font-semibold text-bone shadow-cta transition-all hover:-translate-y-px hover:bg-ember-warm"
        >
          Get a quote <span aria-hidden>&rarr;</span>
        </a>
        <a
          href="/movers"
          class="inline-flex items-center gap-2 rounded-md border border-line-mid bg-paper px-7 py-3.5 font-body text-base font-semibold text-inlet-navy transition hover:bg-bone-warm"
        >
          See where we work
        </a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Base>
