---
import Base from '../layouts/Base.astro';

const title = 'Inlet Move Co. — Vancouver movers, same-week, $150/hr';
const description =
  'Local moving company in Metro Vancouver. Same-week moves from $150/hr ($300 minimum). Quote in 60 seconds. English, Mandarin, Punjabi, Hindi.';
---

<Base title={title} description={description}>
  <section class="container py-24">
    <h1 class="font-display text-display-1 text-inlet-deep">
      Inlet Move Co.
    </h1>
    <p class="mt-6 max-w-prose text-lg text-charcoal/80">
      Marketing site scaffold ready. Components rendering in Phase 3.
    </p>
    <a
      href="/quote"
      class="mt-10 inline-flex items-center gap-2 rounded-md bg-ember px-6 py-3 text-bone shadow-cta transition hover:bg-ember-warm"
    >
      Get a quote
    </a>
  </section>
</Base>
